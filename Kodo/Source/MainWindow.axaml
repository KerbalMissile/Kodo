<!-- Licensed under the Kodo Public License v1.1 -->
<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:avaloniaEdit="clr-namespace:AvaloniaEdit;assembly=AvaloniaEdit"
        xmlns:svg="clr-namespace:Avalonia.Svg.Skia;assembly=Svg.Controls.Skia.Avalonia"
        xmlns:kodo="clr-namespace:Kodo"
        xmlns:kodoModels="clr-namespace:Kodo.Models"
        mc:Ignorable="d"
        x:Class="Kodo.MainWindow"
        x:Name="RootWindow"
        x:CompileBindings="False"
        Width="1100"
        Height="810"
        MinWidth="900"
        MinHeight="620"
        Title="Kodo"
        Background="{Binding WindowBackgroundBrush}"
        WindowState="Maximized"
        KeyDown="MainWindow_OnKeyDown">
    <Window.Styles>
        <Style Selector="Button.chrome">
            <Setter Property="Background" Value="{Binding ButtonBrush}" />
            <Setter Property="Foreground" Value="{Binding PrimaryTextBrush}" />
            <Setter Property="BorderBrush" Value="{Binding SurfaceBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="12,8" />
        </Style>

        <Style Selector="Button.chrome:pointerover">
            <Setter Property="Background" Value="{Binding ButtonHoverBrush}" />
        </Style>

        <Style Selector="Button.chrome:disabled">
            <Setter Property="Background" Value="{Binding ButtonBrush}" />
            <Setter Property="Foreground" Value="{Binding MutedTextBrush}" />
            <Setter Property="BorderBrush" Value="{Binding SurfaceBorderBrush}" />
        </Style>

        <Style Selector="Button.marketaction">
            <Setter Property="Background" Value="{Binding AccentBrush}" />
            <Setter Property="Foreground" Value="{Binding AccentForegroundBrush}" />
            <Setter Property="BorderBrush" Value="{Binding AccentBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="MinWidth" Value="88" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style Selector="Button.marketaction:pointerover">
            <Setter Property="Background" Value="{Binding ButtonHoverBrush}" />
            <Setter Property="BorderBrush" Value="{Binding AccentBrush}" />
            <Setter Property="Foreground" Value="{Binding PrimaryTextBrush}" />
        </Style>

        <Style Selector="Button.marketaction:disabled /template/ ContentPresenter">
            <Setter Property="Background" Value="{Binding AccentBrush}" />
            <Setter Property="Opacity" Value="0.45" />
        </Style>
        <Style Selector="Button.marketaction:disabled">
            <Setter Property="Foreground" Value="{Binding AccentForegroundBrush}" />
            <Setter Property="BorderBrush" Value="{Binding AccentBrush}" />
        </Style>

        <Style Selector="Button.uninstall">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{Binding #RootWindow.PrimaryTextBrush}" />
            <Setter Property="BorderBrush" Value="{Binding #RootWindow.SurfaceBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="MinWidth" Value="92" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <ControlTemplate>
                    <Border Name="PART_Border"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{TemplateBinding CornerRadius}"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter Name="PART_ContentPresenter"
                                          HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}"
                                          Content="{TemplateBinding Content}"
                                          ContentTemplate="{TemplateBinding ContentTemplate}" />
                    </Border>
                </ControlTemplate>
            </Setter>
        </Style>

        <Style Selector="Button.uninstall:pointerover /template/ Border#PART_Border">
            <Setter Property="Background" Value="{Binding #RootWindow.ButtonHoverBrush}" />
        </Style>
        <Style Selector="Button.uninstall:pointerover">
            <Setter Property="BorderBrush" Value="{Binding #RootWindow.AccentBrush}" />
        </Style>

        <Style Selector="Button.uninstall:disabled">
            <Setter Property="Opacity" Value="0.45" />
        </Style>

        <Style Selector="Button.tab">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{Binding MutedTextBrush}" />
            <Setter Property="BorderBrush" Value="{Binding SurfaceBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="999" />
            <Setter Property="Padding" Value="14,8" />
        </Style>

        <Style Selector="Button.tab:pointerover">
            <Setter Property="Background" Value="{Binding ButtonHoverBrush}" />
            <Setter Property="Foreground" Value="{Binding PrimaryTextBrush}" />
        </Style>

        <Style Selector="Button.recent">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{Binding PrimaryTextBrush}" />
            <Setter Property="BorderBrush" Value="{Binding SurfaceBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Padding" Value="12,10" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
        </Style>

        <Style Selector="Button.recent:pointerover">
            <Setter Property="Background" Value="{Binding ButtonHoverBrush}" />
        </Style>

        <Style Selector="Button.activity">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{Binding MutedTextBrush}" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="4,2" />
            <Setter Property="Height" Value="48" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Template">
                <ControlTemplate>
                    <Border Name="PART_Border"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{TemplateBinding CornerRadius}"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter Name="PART_ContentPresenter"
                                          HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}"
                                          Content="{TemplateBinding Content}"
                                          ContentTemplate="{TemplateBinding ContentTemplate}" />
                    </Border>
                </ControlTemplate>
            </Setter>
        </Style>

        <!-- Prevent Avalonia's default template from shifting the ContentPresenter on hover -->
        <Style Selector="Button.activity /template/ ContentPresenter">
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0" />
        </Style>
        <Style Selector="Button.activity:pointerover /template/ ContentPresenter">
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0" />
        </Style>

        <Style Selector="Button.activity:pointerover /template/ Border#PART_Border">
            <Setter Property="Background" Value="{Binding ButtonHoverBrush}" />
        </Style>

        <Style Selector="Button.activity:pointerover">
            <Setter Property="Foreground" Value="{Binding PrimaryTextBrush}" />
        </Style>

        <Style Selector="Button.activity:pressed /template/ Border#PART_Border">
            <Setter Property="Background" Value="{Binding AccentBrush}" />
        </Style>

        <Style Selector="Button.activity:pressed">
            <Setter Property="Foreground" Value="{Binding AccentForegroundBrush}" />
        </Style>

        <Style Selector="Button.activity TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI Symbol,Segoe UI Emoji,Noto Sans Symbols,Apple Symbols,sans-serif" />
        </Style>

        <Style Selector="Button.activity">
            <Setter Property="ToolTip.Placement" Value="RightEdgeAlignedTop" />
            <Setter Property="ToolTip.HorizontalOffset" Value="8" />
        </Style>

        <!-- Status-bar clickable items: same hover/press colours as the sidebar but
             no fixed size - the button shrinks to wrap its text content. -->
        <Style Selector="Button.statusitem">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{Binding MutedTextBrush}" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="6,2" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <ControlTemplate>
                    <Border Name="PART_Border"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{TemplateBinding CornerRadius}"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter Name="PART_ContentPresenter"
                                          HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}"
                                          Content="{TemplateBinding Content}"
                                          ContentTemplate="{TemplateBinding ContentTemplate}" />
                    </Border>
                </ControlTemplate>
            </Setter>
        </Style>
        <Style Selector="Button.statusitem /template/ ContentPresenter">
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0" />
        </Style>
        <Style Selector="Button.statusitem:pointerover /template/ ContentPresenter">
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0" />
        </Style>
        <Style Selector="Button.statusitem:pointerover /template/ Border#PART_Border">
            <Setter Property="Background" Value="{Binding ButtonHoverBrush}" />
        </Style>
        <Style Selector="Button.statusitem:pointerover">
            <Setter Property="Foreground" Value="{Binding PrimaryTextBrush}" />
        </Style>
        <Style Selector="Button.statusitem:pressed /template/ Border#PART_Border">
            <Setter Property="Background" Value="{Binding AccentBrush}" />
        </Style>
        <Style Selector="Button.statusitem:pressed">
            <Setter Property="Foreground" Value="{Binding AccentForegroundBrush}" />
        </Style>

        <Style Selector="Button.editortab">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{Binding MutedTextBrush}" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="14,10" />
            <Setter Property="CornerRadius" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
        </Style>

        <Style Selector="Border.tabwrap">
            <Setter Property="Background" Value="Transparent" />
        </Style>
        <Style Selector="Border.tabwrap:pointerover">
            <Setter Property="Background" Value="{Binding ButtonHoverBrush}" />
        </Style>
        <Style Selector="Border.tabwrap.active">
            <Setter Property="Background" Value="{Binding ButtonBrush}" />
        </Style>

        <Style Selector="Button.editortab:pointerover">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{Binding PrimaryTextBrush}" />
        </Style>

        <Style Selector="Button.openeditor">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{Binding MutedTextBrush}" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="8,6" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
        </Style>

        <Style Selector="Button.openeditor:pointerover">
            <Setter Property="Background" Value="{Binding ButtonHoverBrush}" />
            <Setter Property="Foreground" Value="{Binding PrimaryTextBrush}" />
        </Style>

        <Style Selector="Button.tabclose">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{Binding PrimaryTextBrush}" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Width" Value="28" />
            <Setter Property="Height" Value="28" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Opacity" Value="0" />
        </Style>
        <Style Selector="Button.tabclose:pointerover">
            <Setter Property="Background" Value="{Binding ButtonHoverBrush}" />
            <Setter Property="Foreground" Value="{Binding PrimaryTextBrush}" />
        </Style>
        <Style Selector="Border.tabwrap:pointerover Button.tabclose">
            <Setter Property="Opacity" Value="1" />
        </Style>
        <Style Selector="Button.tabclose.active">
            <Setter Property="Opacity" Value="1" />
            <Setter Property="Foreground" Value="{Binding PrimaryTextBrush}" />
        </Style>
        <Style Selector="Border.tabwrap.active Button.tabclose">
            <Setter Property="Opacity" Value="1" />
            <Setter Property="Foreground" Value="{Binding PrimaryTextBrush}" />
        </Style>

        <!-- Underline: hidden by default, shown on hover and always on active tab -->
        <Style Selector="Border.tabunderline">
            <Setter Property="Opacity" Value="0" />
        </Style>
        <Style Selector="Border.tabwrap:pointerover Border.tabunderline">
            <Setter Property="Opacity" Value="1" />
        </Style>
        <Style Selector="Border.tabwrap.active Border.tabunderlinebase">
            <Setter Property="Opacity" Value="1" />
        </Style>

        <Style Selector="Button.fileitem">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{Binding PrimaryTextBrush}" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="CornerRadius" Value="4" />
        </Style>

        <Style Selector="Button.fileitem:pointerover">
            <Setter Property="Background" Value="{Binding ButtonHoverBrush}" />
        </Style>

        <Style Selector="TextBox.editor">
            <Setter Property="Background" Value="{Binding EditorBackgroundBrush}" />
            <Setter Property="Foreground" Value="{Binding PrimaryTextBrush}" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="Padding" Value="20,18" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontFamily" Value="Cascadia Code,Consolas,Menlo,Segoe UI Emoji,Apple Color Emoji,Noto Color Emoji,Monospace" />
            <Setter Property="TextWrapping" Value="NoWrap" />
            <Setter Property="AcceptsReturn" Value="True" />
            <Setter Property="AcceptsTab" Value="True" />
        </Style>

        <!-- All tooltips size dynamically to their content, capped at 480px -->
        <Style Selector="ToolTip">
            <Setter Property="MaxWidth" Value="480" />
        </Style>
        <Style Selector="ToolTip TextBlock">
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <!-- CheckBox: border and checked background use the live accent colour -->
        <Style Selector="CheckBox">
            <Setter Property="Foreground" Value="{Binding PrimaryTextBrush}" />
        </Style>
        <Style Selector="CheckBox /template/ Border#NormalRectangle">
            <Setter Property="BorderBrush" Value="{Binding AccentBrush}" />
        </Style>
        <Style Selector="CheckBox:checked /template/ Border#NormalRectangle">
            <Setter Property="Background" Value="{Binding AccentBrush}" />
            <Setter Property="BorderBrush" Value="{Binding AccentBrush}" />
        </Style>
        <Style Selector="CheckBox:pointerover /template/ Border#NormalRectangle">
            <Setter Property="BorderBrush" Value="{Binding AccentBrush}" />
            <Setter Property="Opacity" Value="0.8" />
        </Style>
    </Window.Styles>

    <!-- Root: activity bar | file explorer panel | editor/content area -->
    <Grid ColumnDefinitions="60,Auto,*">

        <!-- Activity bar (leftmost icon strip) -->
        <Border Grid.Column="0"
                Background="{Binding SidebarBrush}"
                BorderBrush="{Binding SurfaceBorderBrush}"
                BorderThickness="0,0,1,0">
            <DockPanel>
                <!-- Settings pinned to bottom -->
                <StackPanel DockPanel.Dock="Bottom" Margin="0,0,0,10" Spacing="0" HorizontalAlignment="Stretch">
                    <Button Classes="activity" Click="SettingsButton_OnClick" ToolTip.Tip="Settings (Ctrl+,)">
                        <TextBlock FontSize="16" Text="&#x2699;"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   TextAlignment="Center" />
                    </Button>
                </StackPanel>

                <!-- Main buttons spread down from top -->
                <StackPanel Margin="0,10,0,0" Spacing="0" HorizontalAlignment="Stretch">
                    <Button Classes="activity" Click="HomeButton_OnClick" ToolTip.Tip="Home (Ctrl+H)">
                        <TextBlock FontSize="18" Text="&#x2302;"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   TextAlignment="Center" />
                    </Button>
                    <Button Classes="activity" Click="EditorButton_OnClick" ToolTip.Tip="Editor (Ctrl+Shift+E)">
                        <TextBlock FontSize="18" Text="&#x2630;"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   TextAlignment="Center" />
                    </Button>
                    <Border Height="2"
                            Width="28"
                            CornerRadius="1"
                            Background="{Binding AccentBrush}"
                            Opacity="0.6"
                            HorizontalAlignment="Center"
                            Margin="0,2,0,2" />
                    <Button Classes="activity" Click="NewFileButton_OnClick" ToolTip.Tip="New File (Ctrl+N)">
                        <TextBlock FontSize="18" Text="&#xFF0B;"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   TextAlignment="Center" />
                    </Button>
                    <Button Classes="activity" Click="OpenFileButton_OnClick" ToolTip.Tip="Open File (Ctrl+O)">
                        <TextBlock FontSize="18" Text="&#x2197;"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   TextAlignment="Center" />
                    </Button>
                    <Button Classes="activity"
                            Click="OpenFolderButton_OnClick"
                            ToolTip.Tip="Open Folder (Ctrl+K)"
                            IsVisible="{Binding !IsFolderOpen}">
                        <TextBlock FontSize="18" Text="&#x1F4C1;&#xFE0E;"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   TextAlignment="Center" />
                    </Button>
                    <Button Classes="activity"
                            Click="CloseFolderButton_OnClick"
                            ToolTip.Tip="Close Folder (Ctrl+K)"
                            IsVisible="{Binding IsFolderOpen}">
                        <TextBlock FontSize="18" Text="&#x1F4C2;&#xFE0E;"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   TextAlignment="Center" />
                    </Button>
                    <Button Classes="activity" Click="ExtensionsButton_OnClick" ToolTip.Tip="Extensions (Ctrl+E)">
                        <Viewbox Width="20" Height="20"
                                 HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Canvas Width="24" Height="24">
                                <Path Fill="{Binding $parent[Button].Foreground}"
                                      Data="M20.5 11H19V7a2 2 0 0 0-2-2h-4V3.5a2.5 2.5 0 0 0-5 0V5H4a2 2 0 0 0-2 2v3.8h1.5a2.5 2.5 0 0 1 0 5H2V20a2 2 0 0 0 2 2h3.8v-1.5a2.5 2.5 0 0 1 5 0V22H17a2 2 0 0 0 2-2v-4h1.5a2.5 2.5 0 0 0 0-5Z" />
                            </Canvas>
                        </Viewbox>
                    </Button>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Collapsible file explorer panel -->
        <Border Grid.Column="1"
                Width="{Binding ExplorerPanelWidth}"
                IsVisible="{Binding IsFileExplorerVisible}"
                VerticalAlignment="Stretch"
                Background="{Binding SidebarBrush}"
                BorderBrush="{Binding SurfaceBorderBrush}"
                BorderThickness="0,0,1,0">
            <Grid RowDefinitions="Auto,Auto,*">

                <!-- Explorer header -->
                <Border Grid.Row="0"
                        Background="{Binding TopBarBrush}"
                        BorderBrush="{Binding SurfaceBorderBrush}"
                        BorderThickness="0,0,0,1"
                        Padding="12,8">
                    <Grid ColumnDefinitions="*,Auto,Auto,Auto,Auto">
                        <Grid ColumnDefinitions="Auto,*"
                              ColumnSpacing="6"
                              VerticalAlignment="Center"
                              MinWidth="0">
                            <Border Width="3" Height="16" CornerRadius="2" Background="{Binding AccentBrush}" />
                            <TextBlock Grid.Column="1"
                                       FontSize="11"
                                       FontWeight="SemiBold"
                                       Foreground="{Binding MutedTextBrush}"
                                       VerticalAlignment="Center"
                                       Text="{Binding ExplorerHeaderText}"
                                       ToolTip.Tip="{Binding ExplorerHeaderTooltipText}"
                                       TextTrimming="CharacterEllipsis"
                                       TextWrapping="NoWrap" />
                        </Grid>
                        <Button Grid.Column="1"
                                Classes="activity"
                                Width="28"
                                Height="28"
                                IsVisible="{Binding IsFolderOpen}"
                                Click="ExplorerHeaderNewFileButton_OnClick"
                                ToolTip.Tip="New File in Folder">
                            <Viewbox Width="16" Height="16"
                                     HorizontalAlignment="Center"
                                     VerticalAlignment="Center">
                                <Canvas Width="24" Height="24">
                                    <Path Fill="{Binding $parent[Button].Foreground}"
                                          Data="M6.75 3A2.25 2.25 0 0 0 4.5 5.25v13.5A2.25 2.25 0 0 0 6.75 21h10.5A2.25 2.25 0 0 0 19.5 18.75V8.56a2.25 2.25 0 0 0-.659-1.591l-3.81-3.81A2.25 2.25 0 0 0 13.44 2.5H6.75Zm6 11.25a.75.75 0 0 0-1.5 0v1.5h-1.5a.75.75 0 0 0 0 1.5h1.5v1.5a.75.75 0 0 0 1.5 0v-1.5h1.5a.75.75 0 0 0 0-1.5h-1.5v-1.5Z" />
                                </Canvas>
                            </Viewbox>
                        </Button>
                        <Button Grid.Column="2"
                                Classes="activity"
                                Width="28"
                                Height="28"
                                IsVisible="{Binding IsFolderOpen}"
                                Click="ExplorerHeaderNewFolderButton_OnClick"
                                ToolTip.Tip="New Folder in Folder">
                            <Viewbox Width="16" Height="16"
                                     HorizontalAlignment="Center"
                                     VerticalAlignment="Center">
                                <Canvas Width="24" Height="24">
                                    <Path Fill="{Binding $parent[Button].Foreground}"
                                          Data="M3.75 5.25A2.25 2.25 0 0 1 6 3h3.879c.597 0 1.17.237 1.591.659l1.061 1.06c.14.141.331.22.53.22H18a2.25 2.25 0 0 1 2.25 2.25v.75A.75.75 0 0 1 19.5 8.75h-15A2.25 2.25 0 0 0 2.25 11v7.5A2.25 2.25 0 0 0 4.5 20.75H18A2.25 2.25 0 0 0 20.25 18.5V11A2.25 2.25 0 0 0 18 8.75h-5.189a2.25 2.25 0 0 1-1.591-.659l-1.06-1.06A.75.75 0 0 0 9.629 6H6A.75.75 0 0 0 5.25 6.75V8A.75.75 0 0 1 4.5 8.75H3.75A.75.75 0 0 1 3 8V5.25ZM11.25 12a.75.75 0 0 1 1.5 0v1.5h1.5a.75.75 0 0 1 0 1.5h-1.5v1.5a.75.75 0 0 1-1.5 0v-1.5h-1.5a.75.75 0 0 1 0-1.5h1.5V12Z" />
                                </Canvas>
                            </Viewbox>
                        </Button>
                        <Button Grid.Column="3"
                                Classes="activity"
                                Width="28"
                                Height="28"
                                IsVisible="{Binding IsFolderOpen}"
                                Click="CollapseAllTreeButton_OnClick"
                                ToolTip.Tip="Collapse / Expand All">
                            <TextBlock FontSize="11" Text="&#x25B4;&#x25BE;" Foreground="{Binding MutedTextBrush}" />
                        </Button>
                        <Button Grid.Column="4"
                                Classes="activity"
                                Width="28"
                                Height="28"
                                Click="CollapseExplorerButton_OnClick"
                                ToolTip.Tip="Toggle Explorer (Ctrl+B)">
                            <TextBlock FontSize="11" Text="&#x2715;" Foreground="{Binding PrimaryTextBrush}" />
                        </Button>
                    </Grid>
                </Border>

                <Border Grid.Row="1"
                        IsVisible="{Binding HasOpenEditors}"
                        Background="{Binding SidebarBrush}"
                        BorderBrush="{Binding SurfaceBorderBrush}"
                        BorderThickness="0,0,0,1"
                        Padding="12,10,12,8">
                    <StackPanel Spacing="6" HorizontalAlignment="Stretch">
                        <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                            <Border Width="3" Height="16" CornerRadius="2" Background="{Binding AccentBrush}" />
                            <TextBlock FontSize="11"
                                       FontWeight="SemiBold"
                                       Foreground="{Binding MutedTextBrush}"
                                       VerticalAlignment="Center"
                                       Text="OPEN EDITORS" />
                        </StackPanel>
                        <ItemsControl ItemsSource="{Binding OpenTabs}"
                                      HorizontalAlignment="Stretch">
                            <ItemsControl.ItemContainerTheme>
                                <ControlTheme TargetType="ContentPresenter">
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                    <Setter Property="HorizontalAlignment" Value="Stretch" />
                                </ControlTheme>
                            </ItemsControl.ItemContainerTheme>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="kodoModels:EditorTab">
                                    <Border Classes="tabwrap"
                                            Classes.active="{Binding IsSelected}"
                                            Margin="0,0,0,2"
                                            BorderBrush="Transparent">
                                        <Border.Styles>
                                            <Style Selector="Border.tabwrap.active">
                                                <Setter Property="BorderBrush" Value="{Binding #RootWindow.AccentBrush}" />
                                            </Style>
                                        </Border.Styles>
                                        <Grid ColumnDefinitions="*,Auto">
                                            <Panel>
                                                <Button Classes="openeditor"
                                                        Tag="{Binding}"
                                                        Click="OpenEditorTabButton_OnClick"
                                                        IsVisible="{Binding !IsSelected}"
                                                        ToolTip.Tip="{Binding FullPath}">
                                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                                        <TextBlock FontSize="12"
                                                                   Foreground="{Binding #RootWindow.PrimaryTextBrush}"
                                                                   Text="{Binding DisplayName}"
                                                                   TextTrimming="CharacterEllipsis"
                                                                   MaxWidth="150" />
                                                    </StackPanel>
                                                </Button>
                                                <Button Classes="openeditor"
                                                        Tag="{Binding}"
                                                        Click="OpenEditorTabButton_OnClick"
                                                        IsVisible="{Binding IsSelected}"
                                                        Background="{Binding #RootWindow.ButtonHoverBrush}"
                                                        ToolTip.Tip="{Binding FullPath}">
                                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                                        <TextBlock FontSize="12"
                                                                   Foreground="{Binding #RootWindow.AccentBrush}"
                                                                   IsVisible="{Binding IsDirty}"
                                                                   Text="&#x25CF;" />
                                                        <TextBlock FontSize="12"
                                                                   Foreground="{Binding #RootWindow.PrimaryTextBrush}"
                                                                   Text="{Binding DisplayName}"
                                                                   TextTrimming="CharacterEllipsis"
                                                                   MaxWidth="150" />
                                                    </StackPanel>
                                                </Button>
                                            </Panel>
                                            <Button Grid.Column="1"
                                                    Classes="tabclose"
                                                    Classes.active="{Binding IsSelected}"
                                                    Tag="{Binding}"
                                                    Click="CloseEditorTabButton_OnClick"
                                                    Margin="4,0,3,0"
                                                    ToolTip.Tip="Close tab">
                                                <TextBlock FontSize="11" Text="&#x2715;"
                                                           Foreground="{Binding #RootWindow.PrimaryTextBrush}" />
                                            </Button>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- File tree (only shown when a folder is open) -->
                <ScrollViewer Grid.Row="2"
                              IsVisible="{Binding IsFolderOpen}"
                              HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding FileTreeItems}" Margin="4,4,4,8">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="kodo:FileTreeItem">
                                <Button Classes="fileitem"
                                        Tag="{Binding}"
                                        Click="FileTreeItem_OnClick"
                                        Margin="0,1">
                                    <ToolTip.Tip>
                                        <StackPanel Spacing="2">
                                            <TextBlock Text="{Binding Name}"
                                                       FontWeight="SemiBold"
                                                       FontSize="12" />
                                            <TextBlock Text="{Binding FullPath}"
                                                       FontSize="11"
                                                       Opacity="0.7" />
                                        </StackPanel>
                                    </ToolTip.Tip>
                                    <Button.ContextMenu>
                                        <ContextMenu>
                                            <MenuItem Header="New File"
                                                      Tag="{Binding}"
                                                      Click="NewFileInExplorerMenuItem_OnClick" />
                                            <MenuItem Header="New Folder"
                                                      Tag="{Binding}"
                                                      Click="NewFolderInExplorerMenuItem_OnClick" />
                                            <Separator />
                                            <MenuItem Header="Open"
                                                      Tag="{Binding}"
                                                      Click="OpenExplorerItemMenuItem_OnClick" />
                                            <MenuItem Header="Reveal in File Explorer"
                                                      Tag="{Binding}"
                                                      Click="RevealExplorerItemMenuItem_OnClick" />
                                            <Separator />
                                            <MenuItem Header="Rename"
                                                      Tag="{Binding}"
                                                      Click="RenameFileMenuItem_OnClick" />
                                            <Separator />
                                            <MenuItem Header="Cut"
                                                      Tag="{Binding}"
                                                      Click="CutFileMenuItem_OnClick" />
                                            <MenuItem Header="Copy"
                                                      Tag="{Binding}"
                                                      Click="CopyFileMenuItem_OnClick" />
                                            <MenuItem Header="Paste"
                                                      Tag="{Binding}"
                                                      Click="PasteFileMenuItem_OnClick" />
                                            <Separator />
                                            <MenuItem Header="Copy Name"
                                                      Tag="{Binding}"
                                                      Click="CopyFileNameMenuItem_OnClick" />
                                            <MenuItem Header="Copy Path"
                                                      Tag="{Binding}"
                                                      Click="CopyFilePathMenuItem_OnClick" />
                                            <MenuItem Header="Copy Relative Path"
                                                      Tag="{Binding}"
                                                      Click="CopyRelativeFilePathMenuItem_OnClick" />
                                            <Separator />
                                            <MenuItem Header="Duplicate"
                                                      Tag="{Binding}"
                                                      Click="DuplicateExplorerItemMenuItem_OnClick" />
                                            <MenuItem Header="Delete"
                                                      Tag="{Binding}"
                                                      Click="DeleteFileMenuItem_OnClick" />
                                        </ContextMenu>
                                    </Button.ContextMenu>
                                    <Grid ColumnDefinitions="Auto,Auto,*">
                                        <!-- Indentation spacer -->
                                        <Border Grid.Column="0" Width="{Binding IndentWidth}" />

                                        <!-- Expand/collapse chevron -->
                                        <TextBlock Grid.Column="1"
                                                   FontSize="10"
                                                   Width="16"
                                                   VerticalAlignment="Center"
                                                   Foreground="{Binding #RootWindow.MutedTextBrush}"
                                                   Text="{Binding ChevronText}"
                                                   Margin="0,0,2,0" />

                                        <!-- Icon + name -->
                                        <StackPanel Grid.Column="2"
                                                    Orientation="Horizontal"
                                                    Spacing="6"
                                                    Margin="0,4">
                                            <TextBlock FontSize="13"
                                                       FontFamily="Cascadia Code,Consolas,Menlo,Monospace"
                                                       Width="32"
                                                       TextAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       Text="{Binding Icon}"
                                                       Foreground="{Binding #RootWindow.MutedTextBrush}" />
                                            <TextBlock FontSize="13"
                                                       VerticalAlignment="Center"
                                                       Text="{Binding Name}"
                                                       Foreground="{Binding #RootWindow.PrimaryTextBrush}"
                                                       TextTrimming="CharacterEllipsis"
                                                       MaxWidth="148" />
                                        </StackPanel>
                                    </Grid>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>

        <!-- Main content area (editor + settings) -->
        <Grid Grid.Column="2" RowDefinitions="Auto,*" VerticalAlignment="Stretch">

            <StackPanel Grid.Row="0" Spacing="1">
                <!-- Update available banner -->
                <Border IsVisible="{Binding IsAppUpdateAvailable}"
                        Background="{Binding AccentBrush}"
                        Padding="18,8">
                    <Grid ColumnDefinitions="*,Auto,Auto">
                        <StackPanel Orientation="Horizontal"
                                    Spacing="10"
                                    VerticalAlignment="Center">
                            <TextBlock FontSize="13"
                                       Foreground="{Binding AccentForegroundBrush}"
                                       VerticalAlignment="Center"
                                       Text="A new version of Kodo is available -" />
                            <TextBlock FontSize="13"
                                       FontWeight="SemiBold"
                                       Foreground="{Binding AccentForegroundBrush}"
                                       VerticalAlignment="Center"
                                       Text="{Binding LatestReleaseTag}" />
                        </StackPanel>
                        <Button Grid.Column="1"
                                Classes="chrome"
                                Click="OpenReleasesPageButton_OnClick"
                                VerticalAlignment="Center"
                                Margin="0,0,8,0"
                                ToolTip.Tip="Download the latest version of Kodo"
                                Content="Download Update" />
                        <Button Grid.Column="2"
                                Background="Transparent"
                                BorderThickness="0"
                                Foreground="{Binding AccentForegroundBrush}"
                                Padding="6,4"
                                VerticalAlignment="Center"
                                Click="DismissUpdateBanner_OnClick"
                                ToolTip.Tip="Dismiss">
                            <TextBlock FontSize="13" Text="&#x2715;" />
                        </Button>
                    </Grid>
                </Border>

                <!-- Extension updates banner -->
                <Border IsVisible="{Binding IsExtensionUpdateBannerVisible}"
                        Background="{Binding AccentBrush}"
                        Padding="18,8">
                    <Grid ColumnDefinitions="*,Auto,Auto">
                        <TextBlock FontSize="13"
                                   Foreground="{Binding AccentForegroundBrush}"
                                   VerticalAlignment="Center"
                                   Text="{Binding ExtensionUpdatesBannerText}" />
                        <Button Grid.Column="1"
                                Classes="chrome"
                                Click="OpenMarketplaceFromBannerButton_OnClick"
                                VerticalAlignment="Center"
                                Margin="0,0,8,0"
                                ToolTip.Tip="Go to the Extensions Marketplace"
                                Content="Open Marketplace" />
                        <Button Grid.Column="2"
                                Background="Transparent"
                                BorderThickness="0"
                                Foreground="{Binding AccentForegroundBrush}"
                                Padding="6,4"
                                VerticalAlignment="Center"
                                Click="DismissExtensionUpdateBanner_OnClick"
                                ToolTip.Tip="Dismiss">
                            <TextBlock FontSize="13" Text="&#x2715;" />
                        </Button>
                    </Grid>
                </Border>
            </StackPanel>

            <Panel Grid.Row="1">
            <Grid IsVisible="{Binding IsEditorPageVisible}" IsHitTestVisible="{Binding IsEditorPageVisible}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="4" />
                    <RowDefinition Height="Auto" MaxHeight="420" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Background="{Binding TopBarBrush}"
                        BorderBrush="{Binding SurfaceBorderBrush}"
                        BorderThickness="0,0,0,1"
                        Padding="18,12">
                    <Grid ColumnDefinitions="*,Auto">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <Border Width="28"
                                    Height="28"
                                    CornerRadius="8"
                                    ClipToBounds="True">
                                <Image Source="/Assets/kodo-logo.png"
                                       Stretch="UniformToFill" />
                            </Border>

                            <StackPanel Spacing="2">
                                <TextBlock FontSize="18"
                                           FontWeight="SemiBold"
                                           Foreground="{Binding PrimaryTextBrush}"
                                           Text="Kodo" />
                                <TextBlock FontSize="12"
                                           Foreground="{Binding MutedTextBrush}"
                                           Text="{Binding FileSummaryText}" />
                            </StackPanel>
                        </StackPanel>

                        <StackPanel Grid.Column="1"
                                    Orientation="Horizontal"
                                    Spacing="12"
                                    VerticalAlignment="Center">
                            <Button Classes="chrome"
                                    Click="SaveButton_OnClick"
                                    IsVisible="{Binding CanShowSaveActions}"
                                    ToolTip.Tip="Save (Ctrl+S)"
                                    Content="Save" />
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Grid.Row="1"
                        Background="{Binding TopBarBrush}"
                        BorderBrush="{Binding SurfaceBorderBrush}"
                        BorderThickness="0,0,0,1"
                        IsVisible="{Binding IsEditorTabsVisible}">
                    <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                  VerticalScrollBarVisibility="Disabled">
                        <ItemsControl ItemsSource="{Binding OpenTabs}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="kodoModels:EditorTab">
                                    <Border Classes="tabwrap"
                                            Classes.active="{Binding IsSelected}">
                                        <Border.ContextMenu>
                                            <ContextMenu>
                                                <MenuItem Header="Save"
                                                          Tag="{Binding}"
                                                          Click="SaveEditorTabMenuItem_OnClick" />
                                                <MenuItem Header="Save As..."
                                                          Tag="{Binding}"
                                                          Click="SaveEditorTabAsMenuItem_OnClick" />
                                                <Separator />
                                                <MenuItem Header="Copy Path"
                                                          Tag="{Binding}"
                                                          Click="CopyEditorTabPathMenuItem_OnClick" />
                                                <MenuItem Header="Copy Relative Path"
                                                          Tag="{Binding}"
                                                          Click="CopyEditorTabRelativePathMenuItem_OnClick" />
                                                <MenuItem Header="Reveal in File Explorer"
                                                          Tag="{Binding}"
                                                          Click="RevealEditorTabInExplorerMenuItem_OnClick" />
                                                <Separator />
                                                <MenuItem Header="Close"
                                                          Tag="{Binding}"
                                                          Click="CloseEditorTabButton_OnClick" />
                                                <MenuItem Header="Close Others"
                                                          Tag="{Binding}"
                                                          Click="CloseOtherTabsButton_OnClick" />
                                                <MenuItem Header="Close All"
                                                          Click="CloseAllTabsButton_OnClick" />
                                            </ContextMenu>
                                        </Border.ContextMenu>
                                        <Grid RowDefinitions="Auto,2"
                                              ColumnDefinitions="*,Auto">
                                            <Button Grid.Row="0"
                                                    Grid.Column="0"
                                                    Grid.ColumnSpan="2"
                                                    Classes="editortab"
                                                    Tag="{Binding}"
                                                    Click="OpenEditorTabButton_OnClick"
                                                    IsVisible="{Binding !IsSelected}"
                                                    Padding="14,10,38,10">
                                                <StackPanel Orientation="Horizontal" Spacing="4">
                                                    <TextBlock FontSize="13"
                                                               Foreground="{Binding #RootWindow.MutedTextBrush}"
                                                               Text="{Binding DisplayName}" />
                                                    <TextBlock FontSize="11"
                                                               Foreground="{Binding #RootWindow.AccentBrush}"
                                                               IsVisible="{Binding IsDirty}"
                                                               Text="●"
                                                               VerticalAlignment="Center" />
                                                </StackPanel>
                                            </Button>
                                            <Button Grid.Row="0"
                                                    Grid.Column="0"
                                                    Grid.ColumnSpan="2"
                                                    Classes="editortab"
                                                    Tag="{Binding}"
                                                    Click="OpenEditorTabButton_OnClick"
                                                    IsVisible="{Binding IsSelected}"
                                                    Background="Transparent"
                                                    Padding="14,10,38,10">
                                                <StackPanel Orientation="Horizontal" Spacing="4">
                                                    <TextBlock FontSize="13"
                                                               Foreground="{Binding #RootWindow.PrimaryTextBrush}"
                                                               Text="{Binding DisplayName}" />
                                                    <TextBlock FontSize="11"
                                                               Foreground="{Binding #RootWindow.AccentBrush}"
                                                               IsVisible="{Binding IsDirty}"
                                                               Text="●"
                                                               VerticalAlignment="Center" />
                                                </StackPanel>
                                            </Button>
                                            <Button Grid.Row="0"
                                                    Grid.Column="1"
                                                    Classes="tabclose"
                                                    Classes.active="{Binding IsSelected}"
                                                    Tag="{Binding}"
                                                    Click="CloseEditorTabButton_OnClick"
                                                    Margin="0,0,6,0"
                                                    HorizontalAlignment="Right"
                                                    VerticalAlignment="Center"
                                                    ToolTip.Tip="Close tab">
                                                <TextBlock FontSize="11" Text="&#x2715;"
                                                           Foreground="{Binding #RootWindow.PrimaryTextBrush}" />
                                            </Button>
                                            <Border Grid.Row="1"
                                                    Grid.Column="0"
                                                    Grid.ColumnSpan="2"
                                                    Classes="tabunderline tabunderlinebase"
                                                    Height="2"
                                                    Background="{Binding #RootWindow.AccentBrush}" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Border>

                <Grid Grid.Row="2"
                      Background="{Binding EditorBackgroundBrush}"
                      IsVisible="{Binding IsDocumentViewVisible}">
                    <avaloniaEdit:TextEditor x:Name="EditorTextBox"
                                             Background="{Binding EditorBackgroundBrush}"
                                             Foreground="{Binding PrimaryTextBrush}"
                                             FontFamily="Cascadia Code,Consolas,Menlo,Segoe UI Emoji,Apple Color Emoji,Noto Color Emoji,Monospace"
                                             FontSize="14"
                                             Padding="8,12,18,18"
                                             KeyboardNavigation.TabNavigation="None"
                                             ShowLineNumbers="True"
                                             WordWrap="{Binding IsWordWrapEnabled}"
                                             HorizontalScrollBarVisibility="Auto"
                                             VerticalScrollBarVisibility="Auto"
                                             IsVisible="{Binding IsTextEditorVisible}">
                        <avaloniaEdit:TextEditor.ContextMenu>
                            <ContextMenu Opening="EditorContextMenu_Opening">
                                <MenuItem Name="EditorCutMenuItem"
                                          Header="Cut"
                                          InputGesture="Ctrl+X"
                                          Click="EditorCutMenuItem_OnClick" />
                                <MenuItem Name="EditorCopyMenuItem"
                                          Header="Copy"
                                          InputGesture="Ctrl+C"
                                          Click="EditorCopyMenuItem_OnClick" />
                                <MenuItem Header="Paste"
                                          InputGesture="Ctrl+V"
                                          Click="EditorPasteMenuItem_OnClick" />
                            </ContextMenu>
                        </avaloniaEdit:TextEditor.ContextMenu>
                    </avaloniaEdit:TextEditor>
                    <Grid IsVisible="{Binding IsImagePreviewVisible}"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"
                          RowDefinitions="*,Auto">
                        <!-- Scrollable / zoomable image area -->
                        <ScrollViewer x:Name="ImageScrollViewer"
                                      Grid.Row="0"
                                      HorizontalScrollBarVisibility="Auto"
                                      VerticalScrollBarVisibility="Auto">
                            <Image Source="{Binding CurrentImagePreview}"
                                   Width="{Binding ImageZoomedWidth}"
                                   Height="{Binding ImageZoomedHeight}"
                                   Stretch="Fill"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Margin="24" />
                        </ScrollViewer>
                        <!-- Zoom toolbar -->
                        <Border Grid.Row="1"
                                Background="{Binding TopBarBrush}"
                                BorderBrush="{Binding SurfaceBorderBrush}"
                                BorderThickness="0,1,0,0"
                                Padding="10,6">
                            <StackPanel Orientation="Horizontal"
                                        HorizontalAlignment="Center"
                                        Spacing="4">
                                <Button Classes="chrome"
                                        Width="30" Height="28"
                                        FontSize="14"
                                        Padding="0"
                                        HorizontalContentAlignment="Center"
                                        VerticalContentAlignment="Center"
                                        ToolTip.Tip="Zoom Out (Ctrl+−)"
                                        Click="ZoomOutButton_OnClick">
                                    <TextBlock Text="−"
                                               FontSize="16"
                                               Foreground="{Binding PrimaryTextBrush}"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center" />
                                </Button>
                                <Button Classes="chrome"
                                        MinWidth="56" Height="28"
                                        Padding="8,0"
                                        HorizontalContentAlignment="Center"
                                        VerticalContentAlignment="Center"
                                        ToolTip.Tip="Reset Zoom (Ctrl+0)"
                                        Click="ZoomResetButton_OnClick">
                                    <TextBlock Text="{Binding ImageZoomPercent}"
                                               FontSize="12"
                                               Foreground="{Binding MutedTextBrush}"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center" />
                                </Button>
                                <Button Classes="chrome"
                                        Width="30" Height="28"
                                        FontSize="14"
                                        Padding="0"
                                        HorizontalContentAlignment="Center"
                                        VerticalContentAlignment="Center"
                                        ToolTip.Tip="Zoom In (Ctrl++)"
                                        Click="ZoomInButton_OnClick">
                                    <TextBlock Text="+"
                                               FontSize="16"
                                               Foreground="{Binding PrimaryTextBrush}"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center" />
                                </Button>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <Grid IsVisible="{Binding IsCorruptedFileViewVisible}"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch">
                        <StackPanel HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Spacing="16">
                            <TextBlock FontSize="36"
                                       HorizontalAlignment="Center"
                                       Foreground="{Binding MutedTextBrush}"
                                       Opacity="0.35"
                                       Text="⚠" />
                            <StackPanel Spacing="6" HorizontalAlignment="Center">
                                <TextBlock FontSize="16"
                                           FontWeight="SemiBold"
                                           HorizontalAlignment="Center"
                                           Foreground="{Binding MutedTextBrush}"
                                           Opacity="0.6"
                                           Text="This file is corrupted or unsupported" />
                                <TextBlock FontSize="13"
                                           HorizontalAlignment="Center"
                                           Foreground="{Binding MutedTextBrush}"
                                           Opacity="0.4"
                                           Text="The file appears to be binary and cannot be displayed as text." />
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </Grid>

                <Border Grid.Row="2"
                        Background="{Binding EditorBackgroundBrush}"
                        IsVisible="{Binding IsEmptyStateVisible}">
                    <Grid RowDefinitions="4,*">
                        <!-- Top accent bar - pinned, never scrolls -->
                        <Border Grid.Row="0"
                                Background="{Binding AccentBrush}"
                                Opacity="0.85"
                                HorizontalAlignment="Stretch" />
                    <ScrollViewer Grid.Row="1"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                    <Grid>
                        <Grid Grid.Row="0" Margin="48"
                              HorizontalAlignment="Stretch"
                              VerticalAlignment="Center">
                        <StackPanel
                                    Width="480"
                                    Spacing="22"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center">

                            <!-- Welcome Back header + version pill -->
                            <StackPanel Spacing="2" Margin="4,0,4,4">
                                <Grid ColumnDefinitions="Auto,*,Auto">
                                    <TextBlock Grid.Column="0"
                                               FontSize="13"
                                               FontWeight="Medium"
                                               Foreground="{Binding AccentBrush}"
                                               VerticalAlignment="Center"
                                               Text="KODO" />
                                    <Border Grid.Column="2"
                                            Background="{Binding CardBrush}"
                                            BorderBrush="{Binding SurfaceBorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="12"
                                            Padding="10,3"
                                            VerticalAlignment="Center">
                                        <TextBlock FontSize="11"
                                                   Foreground="{Binding MutedTextBrush}"
                                                   Text="{Binding CurrentAppVersionDisplay}" />
                                    </Border>
                                </Grid>
                                <!-- Viewbox shrinks the text when it would overflow the
                                     480 px card, but never upscales it (DownOnly). -->
                                <!-- Standard greeting (~999,999 in a million) -->
                                <Viewbox Stretch="Uniform" StretchDirection="DownOnly"
                                         HorizontalAlignment="Left"
                                         IsVisible="{Binding !IsTaglineGreeting}">
                                    <TextBlock FontSize="32"
                                               FontWeight="Bold"
                                               Foreground="{Binding PrimaryTextBrush}"
                                               Text="{Binding WelcomeMessage}" />
                                </Viewbox>
                                <!-- One-in-a-million tagline: "Code fast. Stay light" -->
                                <Viewbox Stretch="Uniform" StretchDirection="DownOnly"
                                         HorizontalAlignment="Left"
                                         IsVisible="{Binding IsTaglineGreeting}">
                                    <TextBlock FontSize="32"
                                               FontWeight="Bold"
                                               xml:space="preserve"><Run Foreground="{Binding PrimaryTextBrush}">Code fast. Stay </Run><Run Foreground="{Binding AccentBrush}">light.</Run></TextBlock>
                                </Viewbox>
                            </StackPanel>
                            <Border Padding="26"
                                    Background="{Binding CardBrush}"
                                    BorderBrush="{Binding SurfaceBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="18">
                                <StackPanel Spacing="12">
                                    <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                                        <Border Width="3" Height="30" CornerRadius="2" Background="{Binding AccentBrush}" />
                                        <TextBlock FontSize="26"
                                                   FontWeight="SemiBold"
                                                   Foreground="{Binding PrimaryTextBrush}"
                                                   VerticalAlignment="Center"
                                                   Text="Get Started!" />
                                    </StackPanel>
                                    <TextBlock Foreground="{Binding MutedTextBrush}"
                                               TextWrapping="Wrap"
                                               Text="Open a file or folder to get started, or create something new." />
                                    <StackPanel Orientation="Horizontal" Spacing="10">
                                        <Button Classes="chrome"
                                                Click="NewFileButton_OnClick"
                                                ToolTip.Tip="New File (Ctrl+N)"
                                                Content="New File" />
                                        <Button Classes="chrome"
                                                Click="OpenFileButton_OnClick"
                                                ToolTip.Tip="Open File (Ctrl+O)"
                                                Content="Open File" />
                                        <Button Classes="chrome"
                                                Click="OpenFolderButton_OnClick"
                                                ToolTip.Tip="Open Folder (Ctrl+K)"
                                                Content="Open Folder" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                            <Border Padding="26"
                                    Background="{Binding CardBrush}"
                                    BorderBrush="{Binding SurfaceBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="18">
                                <StackPanel Spacing="12">
                                    <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                                        <Border Width="3" Height="30" CornerRadius="2" Background="{Binding AccentBrush}" />
                                        <TextBlock FontSize="26"
                                                   FontWeight="SemiBold"
                                                   Foreground="{Binding PrimaryTextBrush}"
                                                   VerticalAlignment="Center"
                                                   Text="Visit the Marketplace!" />
                                    </StackPanel>
                                    <TextBlock Foreground="{Binding MutedTextBrush}"
                                               TextWrapping="Wrap"
                                               Text="Visit the Marketplace to explore extensions, syntax highlighting, and themes." />
                                    <StackPanel Orientation="Horizontal" Spacing="10">
                                        <Button Classes="chrome"
                                                Click="OpenMarketplaceButton_OnClick"
                                                ToolTip.Tip="Browse extensions in the marketplace (Ctrl+E)"
                                                Content="Visit Marketplace" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                            <Border Padding="22"
                                    Background="{Binding CardBrush}"
                                    BorderBrush="{Binding SurfaceBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="18">
                                <StackPanel Spacing="12">
                                    <Grid ColumnDefinitions="*,Auto">
                                        <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                                            <Border Width="3" Height="26" CornerRadius="2" Background="{Binding AccentBrush}" />
                                            <TextBlock FontSize="22"
                                                       FontWeight="SemiBold"
                                                       Foreground="{Binding PrimaryTextBrush}"
                                                       VerticalAlignment="Center"
                                                       Text="Recently Edited" />
                                        </StackPanel>
                                        <Button Grid.Column="1"
                                                Classes="chrome"
                                                Click="ClearRecentFilesButton_OnClick"
                                                IsVisible="{Binding HasRecentFiles}"
                                                VerticalAlignment="Center"
                                                FontSize="12"
                                                Padding="8,4"
                                                ToolTip.Tip="Clear the list of recently opened files"
                                                Content="Clear" />
                                    </Grid>
                                    <StackPanel IsVisible="{Binding !HasRecentFiles}"
                                                HorizontalAlignment="Center"
                                                Spacing="8"
                                                Margin="0,8,0,4">
                                        <TextBlock FontSize="32"
                                                   HorizontalAlignment="Center"
                                                   Foreground="{Binding MutedTextBrush}"
                                                   Opacity="0.4"
                                                   Text="&#x1F4C2;" />
                                        <TextBlock FontSize="13"
                                                   HorizontalAlignment="Center"
                                                   Foreground="{Binding MutedTextBrush}"
                                                   Text="No recently opened files!" />
                                    </StackPanel>
                                    <ItemsControl ItemsSource="{Binding RecentFiles}"
                                                  IsVisible="{Binding HasRecentFiles}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="kodo:RecentFileItem">
                                                <Button Classes="recent"
                                                        Tag="{Binding}"
                                                        Click="RecentFileButton_OnClick"
                                                        Margin="0,0,0,4">
                                                    <ToolTip.Tip>
                                                        <StackPanel Spacing="2">
                                                            <TextBlock Text="{Binding DisplayName}"
                                                                       FontWeight="SemiBold"
                                                                       FontSize="12" />
                                                            <TextBlock Text="{Binding Path}"
                                                                       FontSize="11"
                                                                       Opacity="0.7" />
                                                            <TextBlock FontSize="11"
                                                                       Opacity="0.7">
                                                                <Run Text="Last opened " /><Run Text="{Binding LastOpenedLongText}" />
                                                            </TextBlock>
                                                        </StackPanel>
                                                    </ToolTip.Tip>
                                                    <Grid ColumnDefinitions="*,Auto,Auto" MinWidth="400">
                                                        <!-- Filename -->
                                                        <TextBlock Grid.Column="0"
                                                                   FontSize="13"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="{Binding #RootWindow.PrimaryTextBrush}"
                                                                   Text="{Binding DisplayName}"
                                                                   TextTrimming="CharacterEllipsis"
                                                                   VerticalAlignment="Center" />
                                                        <!-- File type / Folder -->
                                                        <TextBlock Grid.Column="1"
                                                                   FontSize="12"
                                                                   Foreground="{Binding #RootWindow.MutedTextBrush}"
                                                                   Text="{Binding FileTypeName}"
                                                                   VerticalAlignment="Center"
                                                                   Margin="16,0,0,0"
                                                                   MinWidth="64"
                                                                   TextAlignment="Left" />
                                                        <!-- Time last opened, right-aligned -->
                                                        <TextBlock Grid.Column="2"
                                                                   FontSize="12"
                                                                   Foreground="{Binding #RootWindow.MutedTextBrush}"
                                                                   Text="{Binding LastOpenedText}"
                                                                   VerticalAlignment="Center"
                                                                   Margin="16,0,0,0"
                                                                   MinWidth="60"
                                                                   TextAlignment="Right" />
                                                    </Grid>
                                                </Button>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        </Grid>
                    </Grid>
                    </ScrollViewer>
                    </Grid>
                </Border>



                <Border Grid.Row="4"
                        IsVisible="{Binding IsTerminalVisible}"
                        Background="{Binding CardBrush}"
                        BorderBrush="{Binding SurfaceBorderBrush}"
                        BorderThickness="0,1,0,1"
                        Height="300">
                    <Grid RowDefinitions="Auto,Auto,*,Auto">
                        <Border Grid.Row="0"
                                Background="{Binding TopBarBrush}"
                                BorderBrush="{Binding SurfaceBorderBrush}"
                                BorderThickness="0,0,0,1"
                                Padding="12,10">
                            <Grid ColumnDefinitions="*,Auto">
                                <StackPanel Orientation="Horizontal"
                                            Spacing="8"
                                            VerticalAlignment="Center">
                                    <Border Width="3" Height="16" CornerRadius="2" Background="{Binding AccentBrush}" VerticalAlignment="Center" />
                                    <TextBlock FontSize="13"
                                               FontWeight="SemiBold"
                                               Foreground="{Binding PrimaryTextBrush}"
                                               VerticalAlignment="Center"
                                               Text="TERMINAL" />
                                    <TextBlock FontSize="12"
                                               Foreground="{Binding MutedTextBrush}"
                                               VerticalAlignment="Center"
                                               Text="{Binding ActiveTerminalShellDisplayName}" />
                                    <TextBlock FontSize="12"
                                               Foreground="{Binding MutedTextBrush}"
                                               VerticalAlignment="Center"
                                               Opacity="0.5"
                                               Text="•" />
                                    <TextBlock FontSize="12"
                                               Foreground="{Binding MutedTextBrush}"
                                               VerticalAlignment="Center"
                                               Text="{Binding ActiveTerminalStatusText}" />
                                </StackPanel>

                                <StackPanel Grid.Column="1"
                                            Orientation="Horizontal"
                                            Spacing="8"
                                            VerticalAlignment="Center">
                                    <ComboBox MinWidth="120"
                                              MaxWidth="240"
                                              ItemsSource="{Binding AvailableTerminalShells}"
                                              SelectedItem="{Binding SelectedTerminalShell, Mode=TwoWay}"
                                              Background="{Binding ButtonBrush}"
                                              Foreground="{Binding PrimaryTextBrush}"
                                              BorderBrush="{Binding SurfaceBorderBrush}"
                                              CornerRadius="8"
                                              Padding="12,8"
                                              VerticalContentAlignment="Center"
                                              ToolTip.Tip="Choose the default shell for new terminals">
                                        <ComboBox.Styles>
                                            <Style Selector="ComboBox /template/ Border#PART_Border">
                                                <Setter Property="MinHeight" Value="0" />
                                            </Style>
                                        </ComboBox.Styles>
                                        <ComboBox.ItemTemplate>
                                            <DataTemplate x:DataType="kodo:TerminalShellOption">
                                                <TextBlock Text="{Binding DisplayName}" />
                                            </DataTemplate>
                                        </ComboBox.ItemTemplate>
                                    </ComboBox>
                                    <Button Classes="chrome"
                                            Focusable="False"
                                            Click="NewTerminalButton_OnClick"
                                            ToolTip.Tip="New terminal (Ctrl+Shift+`)"
                                            Content="+" />
                                    <Button Classes="chrome"
                                            Focusable="False"
                                            Click="ClearTerminalButton_OnClick"
                                            IsEnabled="{Binding HasActiveTerminal}"
                                            ToolTip.Tip="Clear terminal"
                                            Content="Clear" />
                                    <Button Classes="chrome"
                                            Focusable="False"
                                            Click="RestartTerminalButton_OnClick"
                                            IsEnabled="{Binding HasActiveTerminal}"
                                            ToolTip.Tip="Restart active terminal with the selected shell"
                                            Content="Restart" />
                                    <Button Classes="chrome"
                                            Focusable="False"
                                            Click="CloseTerminalButton_OnClick"
                                            IsEnabled="{Binding HasActiveTerminal}"
                                            ToolTip.Tip="Close active terminal"
                                            Content="×" />
                                </StackPanel>
                            </Grid>
                        </Border>

                        <Border Grid.Row="1"
                                Background="{Binding TopBarBrush}"
                                BorderBrush="{Binding SurfaceBorderBrush}"
                                BorderThickness="0,0,0,1">
                            <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                          VerticalScrollBarVisibility="Disabled">
                                <ItemsControl ItemsSource="{Binding TerminalSessions}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <StackPanel Orientation="Horizontal" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="kodoModels:TerminalSession">
                                            <Border Classes="tabwrap"
                                                    Classes.active="{Binding IsSelected}">
                                                <Border.ContextMenu>
                                                    <ContextMenu>
                                                        <MenuItem Header="Rename"
                                                                  Tag="{Binding}"
                                                                  Click="RenameTerminalSessionMenuItem_OnClick" />
                                                        <Separator />
                                                        <MenuItem Header="Restart"
                                                                  Tag="{Binding}"
                                                                  Click="RestartTerminalSessionMenuItem_OnClick" />
                                                        <MenuItem Header="Duplicate"
                                                                  Tag="{Binding}"
                                                                  Click="DuplicateTerminalSessionMenuItem_OnClick" />
                                                        <Separator />
                                                        <MenuItem Header="Close Others"
                                                                  Tag="{Binding}"
                                                                  Click="CloseOtherTerminalSessionsMenuItem_OnClick" />
                                                        <MenuItem Header="Close"
                                                                  Tag="{Binding}"
                                                                  Click="CloseTerminalSessionButton_OnClick" />
                                                    </ContextMenu>
                                                </Border.ContextMenu>
                                                <Grid RowDefinitions="Auto,2"
                                                      ColumnDefinitions="*,Auto">
                                                    <Button Grid.Row="0"
                                                            Grid.Column="0"
                                                            Grid.ColumnSpan="2"
                                                            Classes="editortab"
                                                            Focusable="False"
                                                            Tag="{Binding}"
                                                            Click="OpenTerminalSessionButton_OnClick"
                                                            Background="Transparent"
                                                            Padding="14,10,36,10">
                                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                                            <Border Width="7"
                                                                    Height="7"
                                                                    CornerRadius="4"
                                                                    VerticalAlignment="Center"
                                                                    Background="{Binding StatusDotColor}"
                                                                    ToolTip.Tip="{Binding StatusText}" />
                                                            <TextBlock FontSize="13"
                                                                       Foreground="{Binding #RootWindow.PrimaryTextBrush}"
                                                                       Text="{Binding Title}" />
                                                            <TextBlock FontSize="11"
                                                                       Foreground="{Binding #RootWindow.MutedTextBrush}"
                                                                       Text="{Binding ShellDisplayName}" />
                                                            <TextBlock FontSize="11"
                                                                       Foreground="{Binding #RootWindow.MutedTextBrush}"
                                                                       Opacity="0.6"
                                                                       Text="{Binding StatusText}" />
                                                        </StackPanel>
                                                    </Button>
                                                    <Button Grid.Row="0"
                                                            Grid.Column="1"
                                                            Classes="tabclose"
                                                            Classes.active="{Binding IsSelected}"
                                                            Focusable="False"
                                                            Tag="{Binding}"
                                                            Click="CloseTerminalSessionButton_OnClick"
                                                            Margin="0,0,6,0"
                                                            HorizontalAlignment="Right"
                                                            VerticalAlignment="Center"
                                                            ToolTip.Tip="Close terminal">
                                                        <TextBlock FontSize="11"
                                                                   Text="&#x2715;"
                                                                   Foreground="{Binding #RootWindow.PrimaryTextBrush}" />
                                                    </Button>
                                                    <Border Grid.Row="1"
                                                            Grid.Column="0"
                                                            Grid.ColumnSpan="2"
                                                            Classes="tabunderline tabunderlinebase"
                                                            Height="2"
                                                            Background="{Binding #RootWindow.AccentBrush}" />
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Border>

                        <Grid Grid.Row="2"
                              Focusable="False"
                              IsVisible="{Binding HasActiveTerminal}">
                            <kodo:PseudoConsoleTerminal x:Name="TerminalHostControl" />
                        </Grid>

                        <Border Grid.Row="2"
                                IsVisible="{Binding !HasActiveTerminal}"
                                Background="{Binding EditorBackgroundBrush}">
                            <StackPanel HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Spacing="10">
                                <TextBlock FontSize="15"
                                           FontWeight="SemiBold"
                                           Foreground="{Binding PrimaryTextBrush}"
                                           HorizontalAlignment="Center"
                                           Text="No active terminal" />
                                <TextBlock FontSize="13"
                                           Foreground="{Binding MutedTextBrush}"
                                           HorizontalAlignment="Center"
                                           Text="Choose a shell and open a terminal session." />
                                <Button Classes="chrome"
                                        Click="NewTerminalButton_OnClick"
                                        HorizontalAlignment="Center"
                                        ToolTip.Tip="New terminal (Ctrl+Shift+`)"
                                        Content="Create terminal" />
                            </StackPanel>
                        </Border>

                        <Border Grid.Row="3"
                                x:Name="TerminalFooterBar"
                                Background="{Binding TopBarBrush}"
                                BorderBrush="{Binding SurfaceBorderBrush}"
                                BorderThickness="0,1,0,0"
                                Padding="12,6"
                                PointerPressed="StatusBar_OnPointerPressed">
                            <Grid ColumnDefinitions="*,Auto">
                                <TextBlock Grid.Column="0"
                                           Foreground="{Binding MutedTextBrush}"
                                           VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis"
                                           Text="{Binding ActiveTerminalFooterText}" />
                                <Button Grid.Column="1"
                                        Classes="statusitem"
                                        Focusable="False"
                                        Click="ToggleTerminalButton_OnClick"
                                        ToolTip.Tip="Hide terminal (Ctrl+` or Ctrl+J)">
                                    <TextBlock FontSize="12"
                                               Text="Hide terminal" />
                                </Button>
                            </Grid>
                        </Border>
                    </Grid>
                </Border>

                <Border Grid.Row="5"
                        Background="{Binding TopBarBrush}"
                        BorderBrush="{Binding SurfaceBorderBrush}"
                        BorderThickness="0,1,0,0"
                        Padding="16,10"
                        PointerPressed="StatusBar_OnPointerPressed">
                    <Grid ColumnDefinitions="*,Auto">
                        <!-- Left side: file path when a file is open, welcome text otherwise -->
                        <TextBlock Grid.Column="0"
                                   IsVisible="{Binding HasDocumentOpen}"
                                   Foreground="{Binding MutedTextBrush}"
                                   VerticalAlignment="Center"
                                   TextTrimming="CharacterEllipsis"
                                   Text="{Binding FilePathText}" />
                        <TextBlock Grid.Column="0"
                                   IsVisible="{Binding !HasDocumentOpen}"
                                   Foreground="{Binding MutedTextBrush}"
                                   VerticalAlignment="Center"
                                   Text="Welcome to Kodo!" />

                        <!-- All status items right-aligned, reading left→right with pipe separators.
                             Every "|" carries Margin="8,0" so each item sits symmetrically centred
                             between its neighbours. Content elements carry no extra left/right margin. -->
                        <StackPanel Grid.Column="1"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Center"
                                    Spacing="0">

                            <!-- Language (document open only) -->
                            <TextBlock Foreground="{Binding MutedTextBrush}"
                                       VerticalAlignment="Center"
                                       IsVisible="{Binding HasDocumentOpen}"
                                       Text="{Binding LanguageDisplayText}" />

                            <!-- | (between Language and Encoding, file open only) -->
                            <TextBlock Foreground="{Binding MutedTextBrush}"
                                       VerticalAlignment="Center"
                                       Opacity="0.4"
                                       Margin="8,0"
                                       IsVisible="{Binding HasFileOpen}"
                                       Text="|" />

                            <!-- Encoding button (file open only) -->
                            <Button Classes="statusitem"
                                    IsVisible="{Binding HasFileOpen}"
                                    VerticalAlignment="Center"
                                    VerticalContentAlignment="Center"
                                    ToolTip.Tip="File encoding"
                                    Click="EncodingStatusBarButton_OnClick">
                                <TextBlock FontSize="12"
                                           Text="{Binding EncodingDisplayText}" />
                            </Button>

                            <!-- | (after Encoding, file open only) -->
                            <TextBlock Foreground="{Binding MutedTextBrush}"
                                       VerticalAlignment="Center"
                                       Opacity="0.4"
                                       Margin="8,0"
                                       IsVisible="{Binding HasFileOpen}"
                                       Text="|" />

                            <!-- Word count (text files only) -->
                            <TextBlock Foreground="{Binding MutedTextBrush}"
                                       VerticalAlignment="Center"
                                       IsVisible="{Binding IsWordCountVisible}"
                                       Text="{Binding WordCountText}" />

                            <!-- | (after Word count, text files only) -->
                            <TextBlock Foreground="{Binding MutedTextBrush}"
                                       VerticalAlignment="Center"
                                       Opacity="0.4"
                                       Margin="8,0"
                                       IsVisible="{Binding IsWordCountVisible}"
                                       Text="|" />

                            <!-- Editor stats (document open only) -->
                            <TextBlock Foreground="{Binding MutedTextBrush}"
                                       VerticalAlignment="Center"
                                       IsVisible="{Binding HasDocumentOpen}"
                                       Text="{Binding EditorStatsText}" />

                            <!-- | (after Editor stats, document open only) -->
                            <TextBlock Foreground="{Binding MutedTextBrush}"
                                       VerticalAlignment="Center"
                                       Opacity="0.4"
                                       Margin="8,0"
                                       IsVisible="{Binding HasDocumentOpen}"
                                       Text="|" />

                            <!-- Terminal toggle - always visible -->
                            <Button Classes="statusitem"
                                    VerticalAlignment="Center"
                                    Click="ToggleTerminalButton_OnClick"
                                    ToolTip.Tip="Toggle terminal (Ctrl+` or Ctrl+J)">
                                <TextBlock FontSize="12"
                                           Text="{Binding TerminalStatusBarText}" />
                            </Button>

                            <!-- | (before Find, text files only) -->
                            <TextBlock Foreground="{Binding MutedTextBrush}"
                                       VerticalAlignment="Center"
                                       Opacity="0.4"
                                       Margin="8,0"
                                       IsVisible="{Binding CanShowFindInFile}"
                                       Text="|" />

                            <!-- Find button - far right (text files only) -->
                            <Button Background="Transparent"
                                    BorderThickness="0"
                                    Foreground="{Binding MutedTextBrush}"
                                    Padding="4,0"
                                    VerticalAlignment="Center"
                                    IsVisible="{Binding CanShowFindInFile}"
                                    ToolTip.Tip="Find in file (Ctrl+F)"
                                    Click="ToggleFindPanel_OnClick">
                                <TextBlock FontSize="13"
                                           VerticalAlignment="Center"
                                           Text="&#x1F50D;" />
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Find in file panel -->
                <Border Grid.Row="5"
                        IsVisible="{Binding IsFindPanelActive}"
                        Background="{Binding CardBrush}"
                        BorderBrush="{Binding AccentBrush}"
                        BorderThickness="0,2,0,0"
                        Padding="12,8"
                        VerticalAlignment="Bottom"
                        ZIndex="10">
                    <Grid ColumnDefinitions="*,Auto,Auto,Auto,Auto">
                        <TextBox Grid.Column="0"
                                 Text="{Binding FindText, Mode=TwoWay}"
                                 PlaceholderText="Find..."
                                 Background="{Binding ButtonBrush}"
                                 Foreground="{Binding PrimaryTextBrush}"
                                 BorderBrush="{Binding SurfaceBorderBrush}"
                                 Padding="8,4"
                                 MaxWidth="280"
                                 HorizontalAlignment="Left" />
                        <Button Grid.Column="1"
                                Classes="chrome"
                                Margin="8,0,4,0"
                                Click="FindPrevButton_OnClick"
                                ToolTip.Tip="Previous match"
                                Content="▲" />
                        <Button Grid.Column="2"
                                Classes="chrome"
                                Margin="0,0,4,0"
                                Click="FindNextButton_OnClick"
                                ToolTip.Tip="Next match"
                                Content="▼" />
                        <Button Grid.Column="3"
                                Classes="chrome"
                                Margin="0,0,4,0"
                                Click="FindNextButton_OnClick"
                                ToolTip.Tip="Find next (Enter)"
                                Content="Find" />
                        <Button Grid.Column="4"
                                Background="Transparent"
                                BorderThickness="0"
                                Foreground="{Binding PrimaryTextBrush}"
                                Padding="6,4"
                                Click="CloseFindPanel_OnClick"
                                ToolTip.Tip="Close (Escape)">
                            <TextBlock FontSize="12" Text="&#x2715;" />
                        </Button>
                    </Grid>
                </Border>
            </Grid>

            <Grid IsVisible="{Binding IsTutorialPageVisible}"
                  IsHitTestVisible="{Binding IsTutorialPageVisible}"
                  Background="{Binding EditorBackgroundBrush}"
                  RowDefinitions="Auto,*">
                <Border Grid.Row="0"
                        IsVisible="{Binding IsTutorialHeaderVisible}"
                        Background="{Binding TopBarBrush}"
                        BorderBrush="{Binding SurfaceBorderBrush}"
                        BorderThickness="0,0,0,1"
                        Padding="24,18">
                    <Grid ColumnDefinitions="*">
                        <StackPanel Spacing="4">
                            <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                                <Border Width="3" Height="32" CornerRadius="2" Background="{Binding AccentBrush}" />
                                <TextBlock FontSize="28"
                                           FontWeight="SemiBold"
                                           Foreground="{Binding PrimaryTextBrush}"
                                           VerticalAlignment="Center"
                                           Text="Tutorial" />
                            </StackPanel>
                            <TextBlock FontSize="13"
                                       Foreground="{Binding MutedTextBrush}"
                                       Text="A built-in walkthrough for getting comfortable in Kodo." />
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- ═══ Welcome splash - full-bleed centered, no scroll ═══ -->
                <Grid Grid.Row="1"
                      IsVisible="{Binding IsTutorialWelcomeStep}">
                    <StackPanel Spacing="0"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center">
                        <!-- Logo mark -->
                        <Border Width="72" Height="72"
                                CornerRadius="20"
                                ClipToBounds="True"
                                HorizontalAlignment="Center"
                                Margin="0,0,0,28">
                            <Image Source="/Assets/kodo-logo.png"
                                   Stretch="UniformToFill" />
                        </Border>

                        <!-- Headline -->
                        <TextBlock FontSize="48"
                                   FontWeight="Bold"
                                   Foreground="{Binding PrimaryTextBrush}"
                                   HorizontalAlignment="Center"
                                   TextAlignment="Center"
                                   TextWrapping="Wrap"
                                   Text="Welcome to Kodo!" />

                        <!-- Accent rule -->
                        <Border Height="3"
                                Width="64"
                                CornerRadius="2"
                                Background="{Binding AccentBrush}"
                                HorizontalAlignment="Center"
                                Margin="0,16,0,20" />

                        <!-- Subheading -->
                        <TextBlock FontSize="16"
                                   Foreground="{Binding MutedTextBrush}"
                                   HorizontalAlignment="Center"
                                   TextAlignment="Center"
                                   TextWrapping="Wrap"
                                   MaxWidth="420"
                                   LineHeight="26"
                                   Text="A fast, focused code editor built to stay out of your way. This short tutorial walks you through the essentials - it only takes a minute." />

                        <!-- Progress dots -->
                        <TextBlock FontSize="13"
                                   Foreground="{Binding MutedTextBrush}"
                                   HorizontalAlignment="Center"
                                   Text="{Binding TutorialProgressDotsText}"
                                   Margin="0,32,0,0" />

                        <!-- Nav buttons -->
                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Center"
                                    Spacing="10"
                                    Margin="0,16,0,0">
                            <Button Classes="chrome"
                                    Click="SkipTutorialButton_OnClick"
                                    Content="Skip Tutorial" />
                            <Button Classes="marketaction"
                                    Click="NextTutorialStepButton_OnClick"
                                    Content="Get started" />
                        </StackPanel>
                    </StackPanel>
                </Grid>

                <!-- ═══ Normal step content - scrollable, hidden on step 0 ═══ -->
                <ScrollViewer Grid.Row="1"
                              IsVisible="{Binding IsNotTutorialWelcomeStep}"
                              Padding="24"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <Grid ColumnDefinitions="*,320">
                        <Border Background="{Binding CardBrush}"
                                BorderBrush="{Binding SurfaceBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="20"
                                Padding="28"
                                Margin="0,0,20,0">
                            <StackPanel Spacing="18">
                            <Panel>
                                <!-- Normal step content - hidden on setup step -->
                                <StackPanel IsVisible="{Binding IsNotTutorialSetupStep}"
                                            Spacing="18">
                                <StackPanel Spacing="6">
                                    <TextBlock FontSize="12"
                                               FontWeight="SemiBold"
                                               Foreground="{Binding AccentBrush}"
                                               Text="{Binding TutorialStepLabel}" />
                                    <TextBlock FontSize="13"
                                               Foreground="{Binding MutedTextBrush}"
                                               Text="{Binding TutorialProgressDotsText}" />
                                </StackPanel>

                                <StackPanel Spacing="10">
                                    <Border Background="{Binding ButtonBrush}"
                                            BorderBrush="{Binding SurfaceBorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="999"
                                            Padding="10,4"
                                            HorizontalAlignment="Left">
                                        <TextBlock FontSize="11"
                                                   FontWeight="SemiBold"
                                                   Foreground="{Binding AccentBrush}"
                                                   Text="{Binding TutorialSectionTitle}" />
                                    </Border>
                                    <TextBlock FontSize="32"
                                               FontWeight="Bold"
                                               Foreground="{Binding PrimaryTextBrush}"
                                               TextWrapping="Wrap"
                                               Text="{Binding TutorialTitle}" />
                                    <TextBlock FontSize="14"
                                               Foreground="{Binding MutedTextBrush}"
                                               TextWrapping="Wrap"
                                               LineHeight="24"
                                               Text="{Binding TutorialBody}" />
                                </StackPanel>

                                <Border Background="{Binding ButtonBrush}"
                                        BorderBrush="{Binding SurfaceBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="16"
                                        Padding="18">
                                    <StackPanel Spacing="8">
                                        <TextBlock FontSize="12"
                                                   FontWeight="SemiBold"
                                                   Foreground="{Binding MutedTextBrush}"
                                                   Text="Shortcut" />
                                        <TextBlock FontSize="18"
                                                   FontWeight="SemiBold"
                                                   Foreground="{Binding PrimaryTextBrush}"
                                                   TextWrapping="Wrap"
                                                   Text="{Binding TutorialShortcutText}" />
                                    </StackPanel>
                                </Border>

                            </StackPanel>

                                <!-- Setup step - full-width, two-column layout inside the main card -->
                                <StackPanel IsVisible="{Binding IsTutorialSetupStep}" Spacing="28">

                                    <!-- Header -->
                                    <StackPanel Spacing="6">
                                        <TextBlock FontSize="12"
                                                   FontWeight="SemiBold"
                                                   Foreground="{Binding AccentBrush}"
                                                   Text="{Binding TutorialStepLabel}" />
                                        <TextBlock FontSize="32"
                                                   FontWeight="Bold"
                                                   Foreground="{Binding PrimaryTextBrush}"
                                                   Text="{Binding TutorialTitle}" />
                                        <TextBlock FontSize="14"
                                                   Foreground="{Binding MutedTextBrush}"
                                                   TextWrapping="Wrap"
                                                   LineHeight="22"
                                                   Text="{Binding TutorialBody}" />
                                    </StackPanel>

                                    <!-- Two-column body: appearance | personalization -->
                                    <Grid ColumnDefinitions="*,1,*" ColumnSpacing="0">

                                        <!-- Left: Theme + Accent -->
                                        <StackPanel Grid.Column="0" Spacing="24" Margin="0,0,32,0">

                                            <!-- Theme -->
                                            <StackPanel Spacing="12">
                                                <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                                    <Border Width="3" Height="16" CornerRadius="2" Background="{Binding AccentBrush}" VerticalAlignment="Center" />
                                                    <TextBlock FontSize="12"
                                                               FontWeight="SemiBold"
                                                               Foreground="{Binding PrimaryTextBrush}"
                                                               VerticalAlignment="Center"
                                                               Text="THEME" />
                                                </StackPanel>
                                                <WrapPanel Orientation="Horizontal" ItemSpacing="10" LineSpacing="10">
                                                    <Button Classes="chrome"
                                                            Click="ThemeButton_OnClick"
                                                            Tag="Dark"
                                                            Width="170"
                                                            ToolTip.Tip="Apply Dark theme">
                                                        <StackPanel Spacing="8">
                                                            <Panel>
                                                                <Border Height="72"
                                                                        CornerRadius="10"
                                                                        Background="#1E1E1E"
                                                                        BorderBrush="#2B2B2B"
                                                                        BorderThickness="1" />
                                                                <Border Height="72"
                                                                        CornerRadius="10"
                                                                        BorderThickness="2"
                                                                        BorderBrush="{Binding AccentBrush}"
                                                                        IsVisible="{Binding IsDarkThemeActive}" />
                                                            </Panel>
                                                            <StackPanel Orientation="Horizontal" Spacing="4" HorizontalAlignment="Center">
                                                                <TextBlock Foreground="{Binding PrimaryTextBrush}" Text="Dark" />
                                                                <TextBlock FontSize="11" Foreground="{Binding AccentBrush}"
                                                                           VerticalAlignment="Center" Text="●"
                                                                           IsVisible="{Binding IsDarkThemeActive}" />
                                                            </StackPanel>
                                                        </StackPanel>
                                                    </Button>
                                                    <Button Classes="chrome"
                                                            Click="ThemeButton_OnClick"
                                                            Tag="Light"
                                                            Width="170"
                                                            ToolTip.Tip="Apply Light theme">
                                                        <StackPanel Spacing="8">
                                                            <Panel>
                                                                <Border Height="72"
                                                                        CornerRadius="10"
                                                                        Background="#FFFFFF"
                                                                        BorderBrush="#D7DCE5"
                                                                        BorderThickness="1" />
                                                                <Border Height="72"
                                                                        CornerRadius="10"
                                                                        BorderThickness="2"
                                                                        BorderBrush="{Binding AccentBrush}"
                                                                        IsVisible="{Binding IsLightThemeActive}" />
                                                            </Panel>
                                                            <StackPanel Orientation="Horizontal" Spacing="4" HorizontalAlignment="Center">
                                                                <TextBlock Foreground="{Binding PrimaryTextBrush}" Text="Light" />
                                                                <TextBlock FontSize="11" Foreground="{Binding AccentBrush}"
                                                                           VerticalAlignment="Center" Text="●"
                                                                           IsVisible="{Binding IsLightThemeActive}" />
                                                            </StackPanel>
                                                        </StackPanel>
                                                    </Button>
                                                    <!-- Extension themes -->
                                                    <ItemsControl ItemsSource="{Binding ThemeExtensions}"
                                                                  IsVisible="{Binding HasThemeExtensions}">
                                                        <ItemsControl.ItemsPanel>
                                                            <ItemsPanelTemplate>
                                                                <WrapPanel Orientation="Horizontal" ItemSpacing="10" LineSpacing="10" />
                                                            </ItemsPanelTemplate>
                                                        </ItemsControl.ItemsPanel>
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate x:DataType="kodo:LoadedExtension">
                                                                <Button Classes="chrome"
                                                                        Click="ThemeButton_OnClick"
                                                                        Tag="{Binding ThemeCardThemeId}"
                                                                        Width="170">
                                                                    <ToolTip.Tip>
                                                                        <StackPanel Spacing="2">
                                                                            <TextBlock Text="{Binding ThemeCardDisplayName}"
                                                                                       FontWeight="SemiBold"
                                                                                       FontSize="12" />
                                                                            <TextBlock Text="{Binding SourcePath}"
                                                                                       FontSize="11"
                                                                                       Opacity="0.7" />
                                                                        </StackPanel>
                                                                    </ToolTip.Tip>
                                                                    <StackPanel Spacing="8">
                                                                        <Panel>
                                                                            <Border Height="72"
                                                                                    CornerRadius="10"
                                                                                    Background="{Binding ThemeCardPreviewBackground}"
                                                                                    BorderBrush="{Binding ThemeCardPreviewBorder}"
                                                                                    BorderThickness="1">
                                                                                <Border Width="32"
                                                                                        Height="8"
                                                                                        Margin="10"
                                                                                        HorizontalAlignment="Left"
                                                                                        VerticalAlignment="Top"
                                                                                        CornerRadius="999"
                                                                                        Background="{Binding ThemeCardAccent}" />
                                                                            </Border>
                                                                            <Border Height="72"
                                                                                    CornerRadius="10"
                                                                                    BorderThickness="2"
                                                                                    BorderBrush="{Binding #RootWindow.AccentBrush}"
                                                                                    IsVisible="{Binding IsActiveTheme}" />
                                                                        </Panel>
                                                                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="4">
                                                                            <TextBlock Grid.Column="0"
                                                                                       HorizontalAlignment="Center"
                                                                                       Foreground="{Binding #RootWindow.PrimaryTextBrush}"
                                                                                       Text="{Binding ThemeCardDisplayName}"
                                                                                       TextWrapping="Wrap"
                                                                                       TextAlignment="Center" />
                                                                            <TextBlock Grid.Column="1"
                                                                                       FontSize="11"
                                                                                       Foreground="{Binding #RootWindow.AccentBrush}"
                                                                                       VerticalAlignment="Center"
                                                                                       Text="●"
                                                                                       IsVisible="{Binding IsActiveTheme}" />
                                                                        </Grid>
                                                                    </StackPanel>
                                                                </Button>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </WrapPanel>
                                            </StackPanel>

                                            <!-- Accent Colour -->
                                            <StackPanel Spacing="12">
                                                <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                                    <Border Width="3" Height="16" CornerRadius="2" Background="{Binding AccentBrush}" VerticalAlignment="Center" />
                                                    <TextBlock FontSize="12"
                                                               FontWeight="SemiBold"
                                                               Foreground="{Binding PrimaryTextBrush}"
                                                               VerticalAlignment="Center"
                                                               Text="ACCENT COLOUR" />
                                                </StackPanel>
                                                <StackPanel Orientation="Horizontal" Spacing="10">
                                                    <Button Classes="chrome"
                                                            Click="AccentKodoButton_OnClick"
                                                            Width="120"
                                                            ToolTip.Tip="Use Kodo's default purple accent">
                                                        <StackPanel Spacing="6">
                                                            <Border Height="28" CornerRadius="8" Background="#8C00FF" />
                                                            <StackPanel Orientation="Horizontal" Spacing="4" HorizontalAlignment="Center">
                                                                <TextBlock Foreground="{Binding PrimaryTextBrush}" Text="Kodo" />
                                                                <TextBlock FontSize="11" Foreground="{Binding AccentBrush}"
                                                                           VerticalAlignment="Center" Text="●"
                                                                           IsVisible="{Binding IsAccentKodo}" />
                                                            </StackPanel>
                                                        </StackPanel>
                                                    </Button>
                                                    <Button Classes="chrome"
                                                            Click="AccentWindowsButton_OnClick"
                                                            Width="120"
                                                            ToolTip.Tip="Use your Windows system accent colour">
                                                        <StackPanel Spacing="6">
                                                            <Border Height="28" CornerRadius="8"
                                                                    Background="{Binding AccentBrush}"
                                                                    IsVisible="{Binding IsAccentWindows}" />
                                                            <Border Height="28" CornerRadius="8"
                                                                    Background="{Binding WindowsAccentPreviewBrush}"
                                                                    IsVisible="{Binding !IsAccentWindows}" />
                                                            <StackPanel Orientation="Horizontal" Spacing="4" HorizontalAlignment="Center">
                                                                <TextBlock Foreground="{Binding PrimaryTextBrush}" Text="Windows" />
                                                                <TextBlock FontSize="11" Foreground="{Binding AccentBrush}"
                                                                           VerticalAlignment="Center" Text="●"
                                                                           IsVisible="{Binding IsAccentWindows}" />
                                                            </StackPanel>
                                                        </StackPanel>
                                                    </Button>
                                                    <Button Classes="chrome"
                                                            Click="AccentColorPickerButton_OnClick"
                                                            Width="120"
                                                            ToolTip.Tip="Choose a custom accent colour">
                                                        <StackPanel Spacing="6">
                                                            <Border Height="28" CornerRadius="8"
                                                                    Background="{Binding AccentBrush}"
                                                                    IsVisible="{Binding IsAccentCustom}" />
                                                            <Border Height="28" CornerRadius="8"
                                                                    IsVisible="{Binding !IsAccentCustom}">
                                                                <Border.Background>
                                                                    <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,0%">
                                                                        <GradientStop Color="#FF0000" Offset="0" />
                                                                        <GradientStop Color="#FFFF00" Offset="0.33" />
                                                                        <GradientStop Color="#00FF00" Offset="0.5" />
                                                                        <GradientStop Color="#0000FF" Offset="0.67" />
                                                                        <GradientStop Color="#FF00FF" Offset="1" />
                                                                    </LinearGradientBrush>
                                                                </Border.Background>
                                                            </Border>
                                                            <StackPanel Orientation="Horizontal" Spacing="4" HorizontalAlignment="Center">
                                                                <TextBlock Foreground="{Binding PrimaryTextBrush}" Text="Custom" />
                                                                <TextBlock FontSize="11" Foreground="{Binding AccentBrush}"
                                                                           VerticalAlignment="Center" Text="●"
                                                                           IsVisible="{Binding IsAccentCustom}" />
                                                            </StackPanel>
                                                        </StackPanel>
                                                    </Button>
                                                </StackPanel>
                                            </StackPanel>

                                        </StackPanel>

                                        <!-- Divider -->
                                        <Border Grid.Column="1"
                                                Width="1"
                                                Background="{Binding SurfaceBorderBrush}"
                                                VerticalAlignment="Stretch"
                                                Margin="0,4" />

                                        <!-- Right: Personalization -->
                                        <StackPanel Grid.Column="2" Spacing="16" Margin="32,0,0,0">
                                            <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                                <Border Width="3" Height="16" CornerRadius="2" Background="{Binding AccentBrush}" VerticalAlignment="Center" />
                                                <TextBlock FontSize="12"
                                                           FontWeight="SemiBold"
                                                           Foreground="{Binding PrimaryTextBrush}"
                                                           VerticalAlignment="Center"
                                                           Text="PERSONALIZATION" />
                                            </StackPanel>

                                            <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto,Auto"
                                                  ColumnSpacing="16" RowSpacing="14">
                                                <TextBlock Grid.Row="0" Grid.Column="0"
                                                           VerticalAlignment="Center"
                                                           Foreground="{Binding PrimaryTextBrush}"
                                                           Text="Name" />
                                                <TextBox Grid.Row="0" Grid.Column="1"
                                                         Text="{Binding UserName, Mode=TwoWay}"
                                                         PlaceholderText="e.g. Alex"
                                                         CornerRadius="8"
                                                         Padding="10,8"
                                                         Background="{Binding ButtonBrush}"
                                                         Foreground="{Binding PrimaryTextBrush}"
                                                         BorderBrush="{Binding SurfaceBorderBrush}"
                                                         BorderThickness="1" />

                                                <TextBlock Grid.Row="1" Grid.Column="0"
                                                           VerticalAlignment="Center"
                                                           Foreground="{Binding PrimaryTextBrush}"
                                                           Text="Country" />
                                                <TextBox Grid.Row="1" Grid.Column="1"
                                                         Text="{Binding UserCountry, Mode=TwoWay}"
                                                         PlaceholderText="e.g. CA, US, GB"
                                                         CornerRadius="8"
                                                         Padding="10,8"
                                                         Background="{Binding ButtonBrush}"
                                                         Foreground="{Binding PrimaryTextBrush}"
                                                         BorderBrush="{Binding SurfaceBorderBrush}"
                                                         BorderThickness="1" />

                                                <TextBlock Grid.Row="2" Grid.Column="0"
                                                           VerticalAlignment="Center"
                                                           Foreground="{Binding PrimaryTextBrush}"
                                                           Text="Hemisphere" />
                                                <ComboBox Grid.Row="2" Grid.Column="1"
                                                          SelectedIndex="{Binding UserHemisphereIndex, Mode=TwoWay}"
                                                          Background="{Binding ButtonBrush}"
                                                          Foreground="{Binding PrimaryTextBrush}"
                                                          BorderBrush="{Binding SurfaceBorderBrush}"
                                                          HorizontalAlignment="Stretch"
                                                          CornerRadius="8">
                                                    <ComboBoxItem Content="Auto-detect" />
                                                    <ComboBoxItem Content="Northern" />
                                                    <ComboBoxItem Content="Southern" />
                                                </ComboBox>

                                                <TextBlock Grid.Row="3" Grid.Column="0"
                                                           VerticalAlignment="Center"
                                                           Foreground="{Binding PrimaryTextBrush}"
                                                           Text="Time zone" />
                                                <TextBox Grid.Row="3" Grid.Column="1"
                                                         Text="{Binding UserTimezoneOffset, Mode=TwoWay}"
                                                         PlaceholderText="e.g. -5, +1"
                                                         CornerRadius="8"
                                                         Padding="10,8"
                                                         Background="{Binding ButtonBrush}"
                                                         Foreground="{Binding PrimaryTextBrush}"
                                                         BorderBrush="{Binding SurfaceBorderBrush}"
                                                         BorderThickness="1" />
                                            </Grid>

                                            <TextBlock FontSize="12"
                                                       Foreground="{Binding MutedTextBrush}"
                                                       TextWrapping="Wrap"
                                                       Text="All fields are optional. Changes take effect immediately." />
                                        </StackPanel>

                                    </Grid>

                                </StackPanel>

                            </Panel>

                            <!-- Shared nav row - lives outside both IsVisible panels so there
                                 is only ever one Next button in the tree. This prevents the
                                 flicker caused by both panels briefly rendering during the
                                 property-changed notification cycle when switching steps. -->
                            <StackPanel Orientation="Horizontal"
                                        HorizontalAlignment="Right"
                                        Spacing="10">
                                <Button Classes="chrome"
                                        Click="PreviousTutorialStepButton_OnClick"
                                        IsVisible="{Binding CanGoToPreviousTutorialStep}"
                                        Content="Back" />
                                <Button Classes="chrome"
                                        Click="SkipTutorialButton_OnClick"
                                        Content="Skip Tutorial" />
                                <Button Classes="marketaction"
                                        Click="NextTutorialStepButton_OnClick"
                                        MinWidth="148"
                                        Content="{Binding TutorialPrimaryButtonText}" />
                            </StackPanel>

                            </StackPanel>

                        </Border>

                        <StackPanel Grid.Column="1" Spacing="16">

                            <!-- Standard spotlight card - hidden on the setup step -->
                            <Border IsVisible="{Binding IsNotTutorialSetupStep}"
                                    Background="{Binding CardBrush}"
                                    BorderBrush="{Binding SurfaceBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="20"
                                    Padding="22">
                                <StackPanel Spacing="10">
                                    <TextBlock FontSize="12"
                                               FontWeight="SemiBold"
                                               Foreground="{Binding AccentBrush}"
                                               Text="Spotlight" />
                                    <TextBlock FontSize="22"
                                               FontWeight="SemiBold"
                                               Foreground="{Binding PrimaryTextBrush}"
                                               TextWrapping="Wrap"
                                               Text="{Binding TutorialSpotlightTitle}" />
                                    <TextBlock Foreground="{Binding MutedTextBrush}"
                                               TextWrapping="Wrap"
                                               Text="{Binding TutorialHighlightOne}" />
                                    <TextBlock Foreground="{Binding MutedTextBrush}"
                                               TextWrapping="Wrap"
                                               Text="{Binding TutorialHighlightTwo}" />
                                    <TextBlock Foreground="{Binding MutedTextBrush}"
                                               TextWrapping="Wrap"
                                               Text="{Binding TutorialHighlightThree}" />
                                </StackPanel>
                            </Border>

                            <!-- Setup card - moved to main panel above -->

                        </StackPanel>
                    </Grid>
                </ScrollViewer>
            </Grid>

            <Grid IsVisible="{Binding IsExtensionsPageVisible}"
                  IsHitTestVisible="{Binding IsExtensionsPageVisible}"
                  Background="{Binding EditorBackgroundBrush}"
                  RowDefinitions="Auto,*">
                <Border Grid.Row="0"
                        Background="{Binding TopBarBrush}"
                        BorderBrush="{Binding SurfaceBorderBrush}"
                        BorderThickness="0,0,0,1"
                        Padding="24,18">
                    <Grid ColumnDefinitions="*,Auto">
                        <StackPanel Spacing="4">
                            <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                                <Border Width="3" Height="32" CornerRadius="2" Background="{Binding AccentBrush}" />
                                <TextBlock FontSize="28"
                                           FontWeight="SemiBold"
                                           Foreground="{Binding PrimaryTextBrush}"
                                           VerticalAlignment="Center"
                                           Text="Extensions" />
                            </StackPanel>
                            <TextBlock FontSize="13"
                                       Foreground="{Binding MutedTextBrush}"
                                       Text="Enhance Kodo with language support and themes" />
                        </StackPanel>

                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                            <Button Classes="chrome"
                                    Click="RefreshExtensionsButton_OnClick"
                                    IsEnabled="{Binding !IsRefreshingExtensions}"
                                    ToolTip.Tip="Reload extensions from disk and marketplace"
                                    Content="{Binding RefreshExtensionsButtonText}" />
                            <Button Classes="chrome"
                                    Click="OpenExtensionsFolderButton_OnClick"
                                    ToolTip.Tip="Open the local Extensions folder"
                                    Content="Open Folder" />
                        </StackPanel>
                    </Grid>
                </Border>

                <ScrollViewer Grid.Row="1"
                              Padding="24"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Spacing="12" Margin="0,0,0,96">
                        <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,0,0,8">
                            <Panel>
                                <Button Classes="tab"
                                        Click="InstalledTabButton_OnClick"
                                        Content="Installed"
                                        IsVisible="{Binding !IsInstalledTabSelected}" />
                                <Button Classes="tab"
                                        Click="InstalledTabButton_OnClick"
                                        Content="Installed"
                                        IsVisible="{Binding IsInstalledTabSelected}"
                                        Background="{Binding AccentBrush}"
                                        Foreground="{Binding PrimaryTextBrush}" />
                            </Panel>
                            <Panel>
                                <Button Classes="tab"
                                        Click="MarketplaceTabButton_OnClick"
                                        Content="Marketplace"
                                        IsVisible="{Binding !IsMarketplaceTabSelected}" />
                                <Button Classes="tab"
                                        Click="MarketplaceTabButton_OnClick"
                                        Content="Marketplace"
                                        IsVisible="{Binding IsMarketplaceTabSelected}"
                                        Background="{Binding AccentBrush}"
                                        Foreground="{Binding PrimaryTextBrush}" />
                            </Panel>
                        </StackPanel>

                        <TextBlock Foreground="{Binding MutedTextBrush}"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,8"
                                   Text="{Binding ExtensionsStatusText}" />

                        <Grid ColumnDefinitions="*,Auto,Auto"
                              ColumnSpacing="10"
                              Margin="0,0,0,4">
                            <TextBox Grid.Column="0"
                                     Text="{Binding ExtensionSearchText, Mode=TwoWay}"
                                     PlaceholderText="Search extensions..."
                                     Background="{Binding ButtonBrush}"
                                     Foreground="{Binding PrimaryTextBrush}"
                                     BorderBrush="{Binding SurfaceBorderBrush}"
                                     Padding="10,8" />
                            <Border Grid.Column="1"
                                    MinWidth="96"
                                    MaxWidth="220"
                                    Background="{Binding ButtonBrush}"
                                    BorderBrush="{Binding SurfaceBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="10"
                                    Height="36"
                                    Padding="6,0"
                                    VerticalAlignment="Center"
                                    HorizontalAlignment="Left">
                                <ComboBox ItemsSource="{Binding ExtensionSortOptions}"
                                          SelectedItem="{Binding SelectedExtensionSort, Mode=TwoWay}"
                                          MinWidth="0"
                                          HorizontalAlignment="Left"
                                          VerticalAlignment="Center"
                                          HorizontalContentAlignment="Left"
                                          Background="Transparent"
                                          BorderThickness="0"
                                          FontSize="13"
                                          Foreground="{Binding PrimaryTextBrush}">
                                    <ComboBox.Styles>
                                        <Style Selector="ComboBoxItem">
                                            <Setter Property="Background" Value="{Binding #RootWindow.ButtonBrush}" />
                                            <Setter Property="Foreground" Value="{Binding #RootWindow.PrimaryTextBrush}" />
                                        </Style>
                                    </ComboBox.Styles>
                                </ComboBox>
                            </Border>
                            <Button Grid.Column="2"
                                    Classes="chrome"
                                    Click="UpdateAllMarketplaceExtensionsButton_OnClick"
                                    IsVisible="{Binding IsMarketplaceTabSelected}"
                                    IsEnabled="{Binding CanUpdateAllExtensions}"
                                    ToolTip.Tip="Update all installed extensions to their latest versions"
                                    Content="{Binding UpdateAllExtensionsButtonText}" />
                        </Grid>

                        <StackPanel IsVisible="{Binding IsInstalledTabSelected}">
                            <ItemsControl ItemsSource="{Binding FilteredInstalledExtensions}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="kodo:LoadedExtension">
                                        <Border Background="{Binding #RootWindow.CardBrush}"
                                                BorderBrush="{Binding #RootWindow.SurfaceBorderBrush}"
                                                BorderThickness="1"
                                                CornerRadius="12"
                                                Padding="16"
                                                Margin="0,0,0,8">
                                            <ToolTip.Tip>
                                                <StackPanel Spacing="2">
                                                    <TextBlock Text="{Binding Name}"
                                                               FontWeight="SemiBold"
                                                               FontSize="12" />
                                                    <TextBlock Text="{Binding SourcePath}"
                                                               FontSize="11"
                                                               Opacity="0.7" />
                                                </StackPanel>
                                            </ToolTip.Tip>
                                            <Grid ColumnDefinitions="Auto,*,Auto">
                                                <!-- Icon: image if available, accent box with abbreviation otherwise -->
                                                <Border Width="48" Height="48" CornerRadius="8" Background="{Binding #RootWindow.AccentBrush}" Margin="0,0,16,0"
                                                        IsVisible="{Binding !HasIcon}">
                                                    <TextBlock HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"
                                                               FontSize="14"
                                                               FontWeight="SemiBold"
                                                               Foreground="{Binding #RootWindow.AccentForegroundBrush}"
                                                               Text="{Binding NameAbbreviation}" />
                                                </Border>
                                                <Border Width="48" Height="48" CornerRadius="8" Margin="0,0,16,0"
                                                        IsVisible="{Binding HasIcon}"
                                                        ClipToBounds="True">
                                                    <Panel>
                                                        <Image Source="{Binding IconImage}"
                                                               Width="48"
                                                               Height="48"
                                                               Stretch="Uniform"
                                                               IsVisible="{Binding IconImage, Converter={x:Static ObjectConverters.IsNotNull}}" />
                                                        <svg:Svg Source="{Binding SvgData}"
                                                                 Width="48"
                                                                 Height="48"
                                                                 IsVisible="{Binding SvgData, Converter={x:Static ObjectConverters.IsNotNull}}" />
                                                    </Panel>
                                                </Border>
                                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                                                    <TextBlock FontSize="16" FontWeight="SemiBold" Foreground="{Binding #RootWindow.PrimaryTextBrush}" Text="{Binding Name}" />
                                                    <TextBlock FontSize="12" Foreground="{Binding #RootWindow.MutedTextBrush}" Text="{Binding Description}" TextWrapping="Wrap" />
                                                </StackPanel>
                                                <StackPanel Grid.Column="2"
                                                            Spacing="8"
                                                            HorizontalAlignment="Right"
                                                            VerticalAlignment="Center">
                                                    <TextBlock HorizontalAlignment="Right"
                                                               Foreground="{Binding #RootWindow.MutedTextBrush}"
                                                               Text="{Binding Version}" />
                                                    <StackPanel Orientation="Horizontal"
                                                                HorizontalAlignment="Right"
                                                                Spacing="8">
                                                        <Button Classes="chrome"
                                                                Tag="{Binding}"
                                                                Click="UpdateInstalledExtensionButton_OnClick"
                                                                Content="Update"
                                                                IsVisible="{Binding IsUpdateAvailable}" />
                                                        <Button Classes="uninstall"
                                                                Tag="{Binding}"
                                                                Click="UninstallExtensionButton_OnClick"
                                                                Content="Uninstall" />
                                                    </StackPanel>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <TextBlock Foreground="{Binding MutedTextBrush}"
                                       FontStyle="Italic"
                                       Margin="0,16,0,0"
                                       Text="No extensions installed."
                                       IsVisible="{Binding IsNoExtensionsVisible}" />
                        </StackPanel>

                        <StackPanel IsVisible="{Binding IsMarketplaceTabSelected}">
                            <Border Background="{Binding ButtonBrush}"
                                    BorderBrush="{Binding AccentBrush}"
                                    BorderThickness="1"
                                    CornerRadius="14"
                                    Padding="14"
                                    Margin="0,0,0,12"
                                    IsVisible="{Binding IsMarketplaceConnectivityWarningVisible}">
                                <StackPanel Spacing="4">
                                    <TextBlock FontSize="13"
                                               FontWeight="SemiBold"
                                               Foreground="{Binding PrimaryTextBrush}"
                                               Text="Marketplace connectivity warning" />
                                    <TextBlock Foreground="{Binding MutedTextBrush}"
                                               TextWrapping="Wrap"
                                               Text="{Binding MarketplaceConnectivityMessage}" />
                                </StackPanel>
                            </Border>
                            <ItemsControl ItemsSource="{Binding FilteredMarketplaceExtensions}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="kodo:MarketplaceExtension">
                                        <Border Background="{Binding #RootWindow.CardBrush}"
                                                BorderBrush="{Binding #RootWindow.SurfaceBorderBrush}"
                                                BorderThickness="1"
                                                CornerRadius="12"
                                                Padding="16"
                                                Margin="0,0,0,8">
                                            <Grid ColumnDefinitions="Auto,*,Auto">
                                                <!-- Icon: image if available, accent box with abbreviation otherwise -->
                                                <Border Width="48" Height="48" CornerRadius="8"
                                                        Background="{Binding #RootWindow.AccentBrush}"
                                                        Margin="0,0,16,0"
                                                        IsVisible="{Binding !HasIcon}">
                                                    <TextBlock HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"
                                                               FontSize="14"
                                                               FontWeight="SemiBold"
                                                               Foreground="{Binding #RootWindow.AccentForegroundBrush}"
                                                               Text="{Binding NameAbbreviation}" />
                                                </Border>
                                                <Border Width="48" Height="48" CornerRadius="8"
                                                        Margin="0,0,16,0"
                                                        IsVisible="{Binding HasIcon}"
                                                        ClipToBounds="True">
                                                    <Panel>
                                                        <Image Source="{Binding IconImage}"
                                                               Width="48"
                                                               Height="48"
                                                               Stretch="Uniform"
                                                               IsVisible="{Binding IconImage, Converter={x:Static ObjectConverters.IsNotNull}}" />
                                                        <svg:Svg Source="{Binding SvgData}"
                                                                 Width="48"
                                                                 Height="48"
                                                                 IsVisible="{Binding SvgData, Converter={x:Static ObjectConverters.IsNotNull}}" />
                                                    </Panel>
                                                </Border>

                                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="4">
                                                    <TextBlock FontSize="16"
                                                               FontWeight="SemiBold"
                                                               Foreground="{Binding #RootWindow.PrimaryTextBrush}"
                                                               Text="{Binding Name}" />
                                                    <TextBlock FontSize="12"
                                                               Foreground="{Binding #RootWindow.MutedTextBrush}"
                                                               Text="{Binding Description}"
                                                               TextWrapping="Wrap" />
                                                    <TextBlock FontSize="12"
                                                               Foreground="{Binding #RootWindow.MutedTextBrush}"
                                                               Text="{Binding Author}" />
                                                </StackPanel>

                                                <StackPanel Grid.Column="2"
                                                            Spacing="8"
                                                            HorizontalAlignment="Right"
                                                            VerticalAlignment="Center">
                                                    <TextBlock HorizontalAlignment="Right"
                                                               VerticalAlignment="Center"
                                                               Foreground="{Binding #RootWindow.MutedTextBrush}"
                                                               Text="{Binding Version}" />
                                                    <StackPanel Orientation="Horizontal"
                                                                HorizontalAlignment="Right"
                                                                Spacing="8"
                                                                IsVisible="{Binding !IsInstalled}">
                                                        <!-- Update button: mirrors chrome "Update" in Installed tab -->
                                                        <Button Classes="chrome"
                                                                Tag="{Binding}"
                                                                Click="InstallMarketplaceExtensionButton_OnClick"
                                                                Content="Update"
                                                                IsVisible="{Binding IsUpdateAvailable}" />
                                                        <!-- Install button (not yet installed) -->
                                                        <Button Classes="uninstall"
                                                                Tag="{Binding}"
                                                                Click="InstallMarketplaceExtensionButton_OnClick"
                                                                Content="{Binding InstallButtonText}" />
                                                    </StackPanel>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <StackPanel IsVisible="{Binding IsMarketplaceUnavailableVisible}"
                                        HorizontalAlignment="Center"
                                        Spacing="8"
                                        Margin="0,32,0,0">
                                <TextBlock Foreground="{Binding PrimaryTextBrush}"
                                           FontSize="15"
                                           FontWeight="SemiBold"
                                           HorizontalAlignment="Center"
                                           Text="Marketplace Unavailable" />
                                <TextBlock Foreground="{Binding MutedTextBrush}"
                                           FontSize="13"
                                           HorizontalAlignment="Center"
                                           TextAlignment="Center"
                                           TextWrapping="Wrap"
                                           Text="The Marketplace is currently unavailable. Please wait a few minutes." />
                            </StackPanel>
                            <TextBlock Foreground="{Binding MutedTextBrush}"
                                       FontStyle="Italic"
                                       Margin="0,16,0,0"
                                       Text="No marketplace extensions found."
                                       IsVisible="{Binding IsMarketplaceEmptyVisible}" />
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Grid>

            <Grid IsVisible="{Binding IsSettingsPageVisible}"
                  IsHitTestVisible="{Binding IsSettingsPageVisible}"
                  Background="{Binding EditorBackgroundBrush}"
                  RowDefinitions="Auto,*">
                <Border Grid.Row="0"
                        Background="{Binding TopBarBrush}"
                        BorderBrush="{Binding SurfaceBorderBrush}"
                        BorderThickness="0,0,0,1"
                        Padding="24,18">
                    <Grid ColumnDefinitions="*,Auto">
                        <StackPanel Spacing="4">
                            <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                                <Border Width="3" Height="32" CornerRadius="2" Background="{Binding AccentBrush}" />
                                <TextBlock FontSize="28"
                                           FontWeight="SemiBold"
                                           Foreground="{Binding PrimaryTextBrush}"
                                           VerticalAlignment="Center"
                                           Text="Settings" />
                            </StackPanel>
                        </StackPanel>


                    </Grid>
                </Border>

                <ScrollViewer Grid.Row="1"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                <Grid Margin="24">
                    <Border Background="{Binding CardBrush}"
                            BorderBrush="{Binding SurfaceBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="18"
                            Padding="22"
                            MaxWidth="620"
                            Width="620"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Top">
                        <StackPanel Spacing="16">
                            <Border Height="3"
                                    HorizontalAlignment="Stretch"
                                    Background="{Binding AccentBrush}"
                                    Opacity="0.85" />


                            <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                                <Border Width="3" Height="22" CornerRadius="2" Background="{Binding AccentBrush}" />
                                <TextBlock FontSize="18"
                                           FontWeight="SemiBold"
                                           Foreground="{Binding PrimaryTextBrush}"
                                           VerticalAlignment="Center"
                                           Text="Theme" />
                            </StackPanel>
                            <Grid ColumnDefinitions="Auto,Auto"
                                  ColumnSpacing="10"
                                  HorizontalAlignment="Left">
                                <Button Grid.Column="0"
                                        Classes="chrome"
                                        Click="ThemeButton_OnClick"
                                        Tag="Dark"
                                        Width="170"
                                        ToolTip.Tip="Apply Dark theme">
                                    <StackPanel Spacing="8">
                                        <Panel>
                                            <Border Height="96"
                                                    CornerRadius="12"
                                                    Background="#1E1E1E"
                                                    BorderBrush="#2B2B2B"
                                                    BorderThickness="1" />
                                            <Border Height="96"
                                                    CornerRadius="12"
                                                    BorderThickness="2"
                                                    BorderBrush="{Binding AccentBrush}"
                                                    IsVisible="{Binding IsDarkThemeActive}" />
                                        </Panel>
                                        <StackPanel Orientation="Horizontal" Spacing="4" HorizontalAlignment="Center">
                                            <TextBlock Foreground="{Binding PrimaryTextBrush}" Text="Dark" />
                                            <TextBlock FontSize="11" Foreground="{Binding AccentBrush}"
                                                       VerticalAlignment="Center" Text="●"
                                                       IsVisible="{Binding IsDarkThemeActive}" />
                                        </StackPanel>
                                    </StackPanel>
                                </Button>

                                <Button Grid.Column="1"
                                        Classes="chrome"
                                        Click="ThemeButton_OnClick"
                                        Tag="Light"
                                        Width="170"
                                        ToolTip.Tip="Apply Light theme">
                                    <StackPanel Spacing="8">
                                        <Panel>
                                            <Border Height="96"
                                                    CornerRadius="12"
                                                    Background="#FFFFFF"
                                                    BorderBrush="#D7DCE5"
                                                    BorderThickness="1" />
                                            <Border Height="96"
                                                    CornerRadius="12"
                                                    BorderThickness="2"
                                                    BorderBrush="{Binding AccentBrush}"
                                                    IsVisible="{Binding IsLightThemeActive}" />
                                        </Panel>
                                        <StackPanel Orientation="Horizontal" Spacing="4" HorizontalAlignment="Center">
                                            <TextBlock Foreground="{Binding PrimaryTextBrush}" Text="Light" />
                                            <TextBlock FontSize="11" Foreground="{Binding AccentBrush}"
                                                       VerticalAlignment="Center" Text="●"
                                                       IsVisible="{Binding IsLightThemeActive}" />
                                        </StackPanel>
                                    </StackPanel>
                                </Button>
                            </Grid>

                            <StackPanel Spacing="10"
                                        IsVisible="{Binding HasThemeExtensions}">
                                <TextBlock FontSize="14"
                                           FontWeight="SemiBold"
                                           Foreground="{Binding PrimaryTextBrush}"
                                           Text="Installed Theme Extensions" />
                                <ItemsControl ItemsSource="{Binding ThemeExtensions}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <StackPanel Orientation="Horizontal" Spacing="10" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="kodo:LoadedExtension">
                                            <Button Classes="chrome"
                                                    Click="ThemeButton_OnClick"
                                                    Tag="{Binding ThemeCardThemeId}"
                                                    Width="170">
                                                <ToolTip.Tip>
                                                    <StackPanel Spacing="2">
                                                        <TextBlock Text="{Binding ThemeCardDisplayName}"
                                                                   FontWeight="SemiBold"
                                                                   FontSize="12" />
                                                        <TextBlock Text="{Binding SourcePath}"
                                                                   FontSize="11"
                                                                   Opacity="0.7" />
                                                    </StackPanel>
                                                </ToolTip.Tip>
                                                <StackPanel Spacing="8">
                                                    <Panel>
                                                        <Border Height="96"
                                                                CornerRadius="12"
                                                                Background="{Binding ThemeCardPreviewBackground}"
                                                                BorderBrush="{Binding ThemeCardPreviewBorder}"
                                                                BorderThickness="1">
                                                            <Border Width="42"
                                                                    Height="10"
                                                                    Margin="12"
                                                                    HorizontalAlignment="Left"
                                                                    VerticalAlignment="Top"
                                                                    CornerRadius="999"
                                                                    Background="{Binding ThemeCardAccent}" />
                                                        </Border>
                                                        <Border Height="96"
                                                                CornerRadius="12"
                                                                BorderThickness="2"
                                                                BorderBrush="{Binding #RootWindow.AccentBrush}"
                                                                IsVisible="{Binding IsActiveTheme}" />
                                                    </Panel>
                                                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="4">
                                                        <TextBlock Grid.Column="0"
                                                                   HorizontalAlignment="Center"
                                                                   Foreground="{Binding #RootWindow.PrimaryTextBrush}"
                                                                   Text="{Binding ThemeCardDisplayName}"
                                                                   TextTrimming="CharacterEllipsis" />
                                                        <TextBlock Grid.Column="1"
                                                                   FontSize="11"
                                                                   Foreground="{Binding #RootWindow.AccentBrush}"
                                                                   VerticalAlignment="Center"
                                                                   Text="●"
                                                                   IsVisible="{Binding IsActiveTheme}" />
                                                    </Grid>
                                                </StackPanel>
                                            </Button>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>

                            <TextBlock Foreground="{Binding MutedTextBrush}"
                                       Text="{Binding ThemeStatusText}" />

                            <Border Height="1"
                                    Background="{Binding SurfaceBorderBrush}" />

                            <!-- Accent Colour -->
                            <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                                <Border Width="3" Height="22" CornerRadius="2" Background="{Binding AccentBrush}" />
                                <TextBlock FontSize="18"
                                           FontWeight="SemiBold"
                                           Foreground="{Binding PrimaryTextBrush}"
                                           VerticalAlignment="Center"
                                           Text="Accent Colour" />
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <Button Classes="chrome"
                                        Click="AccentKodoButton_OnClick"
                                        Width="120"
                                        ToolTip.Tip="Use Kodo's default purple accent">
                                    <StackPanel Spacing="6">
                                        <Border Height="28" CornerRadius="8" Background="#8C00FF" />
                                        <StackPanel Orientation="Horizontal" Spacing="4" HorizontalAlignment="Center">
                                            <TextBlock Foreground="{Binding PrimaryTextBrush}" Text="Kodo" />
                                            <TextBlock FontSize="11" Foreground="{Binding AccentBrush}"
                                                       VerticalAlignment="Center" Text="●"
                                                       IsVisible="{Binding IsAccentKodo}" />
                                        </StackPanel>
                                    </StackPanel>
                                </Button>

                                <Button Classes="chrome"
                                        Click="AccentWindowsButton_OnClick"
                                        Width="120"
                                        ToolTip.Tip="Use your Windows system accent colour">
                                    <StackPanel Spacing="6">
                                        <Border Height="28" CornerRadius="8" Background="{Binding AccentBrush}"
                                                IsVisible="{Binding IsAccentWindows}" />
                                        <Border Height="28" CornerRadius="8" Background="{Binding WindowsAccentPreviewBrush}"
                                                IsVisible="{Binding !IsAccentWindows}" />
                                        <StackPanel Orientation="Horizontal" Spacing="4" HorizontalAlignment="Center">
                                            <TextBlock Foreground="{Binding PrimaryTextBrush}" Text="Windows" />
                                            <TextBlock FontSize="11" Foreground="{Binding AccentBrush}"
                                                       VerticalAlignment="Center" Text="●"
                                                       IsVisible="{Binding IsAccentWindows}" />
                                        </StackPanel>
                                    </StackPanel>
                                </Button>

                                <Button Classes="chrome"
                                        Click="AccentColorPickerButton_OnClick"
                                        Width="120"
                                        ToolTip.Tip="Choose a custom accent colour">
                                    <StackPanel Spacing="6">
                                        <Border Height="28" CornerRadius="8" Background="{Binding AccentBrush}"
                                                IsVisible="{Binding IsAccentCustom}" />
                                        <Border Height="28" CornerRadius="8"
                                                IsVisible="{Binding !IsAccentCustom}">
                                            <Border.Background>
                                                <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,0%">
                                                    <GradientStop Color="#FF0000" Offset="0" />
                                                    <GradientStop Color="#FFFF00" Offset="0.33" />
                                                    <GradientStop Color="#00FF00" Offset="0.5" />
                                                    <GradientStop Color="#0000FF" Offset="0.67" />
                                                    <GradientStop Color="#FF00FF" Offset="1" />
                                                </LinearGradientBrush>
                                            </Border.Background>
                                        </Border>
                                        <StackPanel Orientation="Horizontal" Spacing="4" HorizontalAlignment="Center">
                                            <TextBlock Foreground="{Binding PrimaryTextBrush}" Text="Custom" />
                                            <TextBlock FontSize="11" Foreground="{Binding AccentBrush}"
                                                       VerticalAlignment="Center" Text="●"
                                                       IsVisible="{Binding IsAccentCustom}" />
                                        </StackPanel>
                                    </StackPanel>
                                </Button>
                            </StackPanel>

                            <Border Height="1"
                                    Background="{Binding SurfaceBorderBrush}" />

                            <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                                <Border Width="3" Height="22" CornerRadius="2" Background="{Binding AccentBrush}" />
                                <TextBlock FontSize="18"
                                           FontWeight="SemiBold"
                                           Foreground="{Binding PrimaryTextBrush}"
                                           VerticalAlignment="Center"
                                           Text="Editor" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <CheckBox IsChecked="{Binding IsWordWrapEnabled, Mode=TwoWay}"
                                          VerticalAlignment="Center" />
                                <TextBlock VerticalAlignment="Center"
                                           Foreground="{Binding PrimaryTextBrush}"
                                           Text="Enable word wrap" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="12"
                                        VerticalAlignment="Center">
                                <TextBlock VerticalAlignment="Center"
                                           Foreground="{Binding PrimaryTextBrush}"
                                           Text="Tab size" />
                                <ComboBox Width="120"
                                          SelectedIndex="{Binding TabSizeIndex, Mode=TwoWay}">
                                    <ComboBoxItem Content="2 spaces" />
                                    <ComboBoxItem Content="4 spaces" />
                                    <ComboBoxItem Content="8 spaces" />
                                </ComboBox>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="12"
                                        VerticalAlignment="Center">
                                <TextBlock VerticalAlignment="Center"
                                           Foreground="{Binding PrimaryTextBrush}"
                                           Text="Font size" />
                                <Button Classes="chrome"
                                        Padding="8,4"
                                        FontSize="16"
                                        Click="DecreaseFontSizeButton_OnClick"
                                        Content="−"
                                        ToolTip.Tip="Decrease font size" />
                                <TextBlock VerticalAlignment="Center"
                                           Foreground="{Binding PrimaryTextBrush}"
                                           MinWidth="28"
                                           TextAlignment="Center"
                                           Text="{Binding EditorFontSize}" />
                                <Button Classes="chrome"
                                        Padding="8,4"
                                        FontSize="16"
                                        Click="IncreaseFontSizeButton_OnClick"
                                        Content="+"
                                        ToolTip.Tip="Increase font size" />
                            </StackPanel>
                            <TextBlock Foreground="{Binding MutedTextBrush}"
                                       TextWrapping="Wrap"
                                       Text="{Binding EditorBehaviorStatusText}" />

                            <Border Height="1"
                                    Background="{Binding SurfaceBorderBrush}" />

                            <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                                <Border Width="3" Height="22" CornerRadius="2" Background="{Binding AccentBrush}" />
                                <TextBlock FontSize="18"
                                           FontWeight="SemiBold"
                                           Foreground="{Binding PrimaryTextBrush}"
                                           VerticalAlignment="Center"
                                           Text="Terminal" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="12"
                                        VerticalAlignment="Center">
                                <TextBlock VerticalAlignment="Center"
                                           Foreground="{Binding PrimaryTextBrush}"
                                           Text="Default shell" />
                                <ComboBox Width="220"
                                          ItemsSource="{Binding AvailableTerminalShells}"
                                          SelectedItem="{Binding SelectedTerminalShell, Mode=TwoWay}"
                                          Background="{Binding ButtonBrush}"
                                          Foreground="{Binding PrimaryTextBrush}"
                                          BorderBrush="{Binding SurfaceBorderBrush}"
                                          CornerRadius="8">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate x:DataType="kodo:TerminalShellOption">
                                            <TextBlock Text="{Binding DisplayName}" />
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                            </StackPanel>
                            <TextBlock Foreground="{Binding MutedTextBrush}"
                                       TextWrapping="Wrap"
                                       Text="New terminal sessions use the selected shell. PowerShell is preferred when it is available." />

                            <Border Height="1"
                                    Background="{Binding SurfaceBorderBrush}" />

                            <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                                <Border Width="3" Height="22" CornerRadius="2" Background="{Binding AccentBrush}" />
                                <TextBlock FontSize="18"
                                           FontWeight="SemiBold"
                                           Foreground="{Binding PrimaryTextBrush}"
                                           VerticalAlignment="Center"
                                           Text="Display" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <CheckBox IsChecked="{Binding IsStatusBarFilePathVisible, Mode=TwoWay}"
                                          VerticalAlignment="Center" />
                                <TextBlock VerticalAlignment="Center"
                                           Foreground="{Binding PrimaryTextBrush}"
                                           Text="Show full file paths in the status bar" />
                            </StackPanel>
                            <TextBlock Foreground="{Binding MutedTextBrush}"
                                       TextWrapping="Wrap"
                                       Text="{Binding StatusBarFilePathVisibilityText}" />

                            <Border Height="1"
                                    Background="{Binding SurfaceBorderBrush}" />

                            <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                                <Border Width="3" Height="22" CornerRadius="2" Background="{Binding AccentBrush}" />
                                <TextBlock FontSize="18"
                                           FontWeight="SemiBold"
                                           Foreground="{Binding PrimaryTextBrush}"
                                           VerticalAlignment="Center"
                                           Text="Tabs &amp; Launch" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <CheckBox IsChecked="{Binding IsConfirmBeforeClosingUnsavedTabsEnabled, Mode=TwoWay}"
                                          VerticalAlignment="Center" />
                                <TextBlock VerticalAlignment="Center"
                                           Foreground="{Binding PrimaryTextBrush}"
                                           Text="Confirm before closing unsaved tabs" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <CheckBox IsChecked="{Binding IsRestoreOpenTabsOnLaunchEnabled, Mode=TwoWay}"
                                          VerticalAlignment="Center" />
                                <TextBlock VerticalAlignment="Center"
                                           Foreground="{Binding PrimaryTextBrush}"
                                           Text="Restore open tabs on launch" />
                            </StackPanel>
                            <TextBlock Foreground="{Binding MutedTextBrush}"
                                       TextWrapping="Wrap"
                                       Text="{Binding TabRestoreStatusText}" />

                            <Border Height="1"
                                    Background="{Binding SurfaceBorderBrush}" />

                            <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                                <Border Width="3" Height="22" CornerRadius="2" Background="{Binding AccentBrush}" />
                                <TextBlock FontSize="18"
                                           FontWeight="SemiBold"
                                           Foreground="{Binding PrimaryTextBrush}"
                                           VerticalAlignment="Center"
                                           Text="Autosave" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <CheckBox IsChecked="{Binding IsAutoSaveEnabled, Mode=TwoWay}"
                                          VerticalAlignment="Center" />
                                <TextBlock VerticalAlignment="Center"
                                           Foreground="{Binding PrimaryTextBrush}"
                                           Text="Enable autosave" />
                            </StackPanel>
                            <TextBlock Foreground="{Binding MutedTextBrush}"
                                       TextWrapping="Wrap"
                                       Text="{Binding AutoSaveStatusText}" />

                            <Border Height="1"
                                    Background="{Binding SurfaceBorderBrush}" />

                            <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                                <Border Width="3" Height="22" CornerRadius="2" Background="{Binding AccentBrush}" />
                                <TextBlock FontSize="18"
                                           FontWeight="SemiBold"
                                           Foreground="{Binding PrimaryTextBrush}"
                                           VerticalAlignment="Center"
                                           Text="Discord Rich Presence" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <CheckBox IsChecked="{Binding IsDiscordRichPresenceEnabled, Mode=TwoWay}"
                                          VerticalAlignment="Center" />
                                <TextBlock VerticalAlignment="Center"
                                           Foreground="{Binding PrimaryTextBrush}"
                                           Text="Enable Discord Rich Presence" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="12" Margin="28,0,0,0"
                                        IsVisible="{Binding IsDiscordRichPresenceEnabled}">
                                <CheckBox IsChecked="{Binding IsDiscordImprovedRpcEnabled, Mode=TwoWay}"
                                          VerticalAlignment="Center" />
                                <StackPanel Spacing="2">
                                    <TextBlock VerticalAlignment="Center"
                                               Foreground="{Binding PrimaryTextBrush}"
                                               Text="Improved RPC [EXPERIMENTAL]" />
                                    <TextBlock Foreground="{Binding MutedTextBrush}"
                                               FontSize="11"
                                               Text="Shows language, dirty state, page context, and open tab count." />
                                </StackPanel>
                            </StackPanel>
                            <TextBlock Foreground="{Binding MutedTextBrush}"
                                       TextWrapping="Wrap"
                                       Text="{Binding DiscordRichPresenceStatusText}" />

                            <Border Height="1"
                                    Background="{Binding SurfaceBorderBrush}" />

                            <!-- Personalization -->
                            <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                                <Border Width="3" Height="22" CornerRadius="2" Background="{Binding AccentBrush}" />
                                <TextBlock FontSize="18"
                                           FontWeight="SemiBold"
                                           Foreground="{Binding PrimaryTextBrush}"
                                           VerticalAlignment="Center"
                                           Text="{Binding LabelPersonalization}" />
                            </StackPanel>

                            <StackPanel Spacing="8">
                                <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                                    <TextBlock Width="120"
                                               VerticalAlignment="Center"
                                               Foreground="{Binding PrimaryTextBrush}"
                                               Text="Name" />
                                    <TextBox Width="220"
                                             Text="{Binding UserName, Mode=TwoWay}"
                                             PlaceholderText="e.g. Alex (optional)"
                                             CornerRadius="8"
                                             Padding="10,6"
                                             Background="{Binding ButtonBrush}"
                                             Foreground="{Binding PrimaryTextBrush}"
                                             BorderBrush="{Binding SurfaceBorderBrush}"
                                             BorderThickness="1" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                                    <TextBlock Width="120"
                                               VerticalAlignment="Center"
                                               Foreground="{Binding PrimaryTextBrush}"
                                               Text="Country" />
                                    <TextBox Width="220"
                                             Text="{Binding UserCountry, Mode=TwoWay}"
                                             PlaceholderText="e.g. CA, US, GB (auto-detected)"
                                             CornerRadius="8"
                                             Padding="10,6"
                                             Background="{Binding ButtonBrush}"
                                             Foreground="{Binding PrimaryTextBrush}"
                                             BorderBrush="{Binding SurfaceBorderBrush}"
                                             BorderThickness="1" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                                    <TextBlock Width="120"
                                               VerticalAlignment="Center"
                                               Foreground="{Binding PrimaryTextBrush}"
                                               Text="Hemisphere" />
                                    <ComboBox Width="220"
                                              SelectedIndex="{Binding UserHemisphereIndex, Mode=TwoWay}"
                                              Background="{Binding ButtonBrush}"
                                              Foreground="{Binding PrimaryTextBrush}"
                                              BorderBrush="{Binding SurfaceBorderBrush}"
                                              CornerRadius="8">
                                        <ComboBoxItem Content="Auto-detect from country" />
                                        <ComboBoxItem Content="Northern hemisphere" />
                                        <ComboBoxItem Content="Southern hemisphere" />
                                    </ComboBox>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                                    <TextBlock Width="120"
                                               VerticalAlignment="Center"
                                               Foreground="{Binding PrimaryTextBrush}"
                                               Text="Time zone offset" />
                                    <TextBox Width="220"
                                             Text="{Binding UserTimezoneOffset, Mode=TwoWay}"
                                             PlaceholderText="e.g. -5, +1 (auto-detected)"
                                             CornerRadius="8"
                                             Padding="10,6"
                                             Background="{Binding ButtonBrush}"
                                             Foreground="{Binding PrimaryTextBrush}"
                                             BorderBrush="{Binding SurfaceBorderBrush}"
                                             BorderThickness="1" />
                                </StackPanel>
                            </StackPanel>
                            <TextBlock Foreground="{Binding MutedTextBrush}"
                                       TextWrapping="Wrap"
                                       Text="{Binding LabelPersonalizationDescription}" />

                            <Border Height="1"
                                    Background="{Binding SurfaceBorderBrush}" />

                            <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                                <Border Width="3" Height="22" CornerRadius="2" Background="{Binding AccentBrush}" />
                                    <TextBlock FontSize="18"
                                        FontWeight="SemiBold"
                                        Foreground="{Binding PrimaryTextBrush}"
                                        VerticalAlignment="Center"
                                        Text="Help" />
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Button Classes="chrome"
                                        Click="OpenTutorialButton_OnClick"
                                        ToolTip.Tip="Launch the built-in Kodo tutorial"
                                        Content="Open Tutorial" />
                                <Button Classes="chrome"
                                        Click="OpenDiscordButton_OnClick"
                                        ToolTip.Tip="Join the Kodo community on Discord">
                                    <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                        <TextBlock Text="Join the Discord Server"
                                                   VerticalAlignment="Center" />
                                    </StackPanel>
                                </Button>
                                <Button Classes="chrome"
                                        Click="OpenWebsiteButton_OnClick"
                                        ToolTip.Tip="Open the Kodo website in your browser"
                                        Content="Visit Website" />
                            </StackPanel>
                            <Border Height="1"
                                    Background="{Binding SurfaceBorderBrush}" />

                            <!-- Developer Options -->
                            <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                                <Border Width="3" Height="22" CornerRadius="2" Background="{Binding AccentBrush}" />
                                <TextBlock FontSize="18"
                                           FontWeight="SemiBold"
                                           Foreground="{Binding PrimaryTextBrush}"
                                           VerticalAlignment="Center"
                                           Text="Developer Options" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <CheckBox IsChecked="{Binding IsDeveloperOptionsVisible, Mode=TwoWay}"
                                          VerticalAlignment="Center" />
                                <TextBlock VerticalAlignment="Center"
                                           Foreground="{Binding PrimaryTextBrush}"
                                           Text="Show developer options" />
                            </StackPanel>
                            <StackPanel Spacing="8"
                                        IsVisible="{Binding IsDeveloperOptionsVisible}">
                                <TextBlock Foreground="{Binding MutedTextBrush}"
                                           TextWrapping="Wrap"
                                           Text="Open folders Kodo uses on this machine for logs, settings, and extensions." />
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <Button Classes="chrome"
                                            Click="OpenCrashLogFolderButton_OnClick"
                                            ToolTip.Tip="{Binding CrashLogFolderPath}"
                                            Content="Open Crash Logs Folder" />
                                    <Button Classes="chrome"
                                            Click="OpenSettingsFolderButton_OnClick"
                                            ToolTip.Tip="{Binding SettingsFolderPath}"
                                            Content="Open Settings Folder" />
                                    <Button Classes="chrome"
                                            Click="OpenExtensionsFolderButton_OnClick"
                                            ToolTip.Tip="Open the local Extensions folder used for .kox files"
                                            Content="Open Extensions Folder" />
                                </StackPanel>
                            </StackPanel>

                            <Border Height="1"
                                    Background="{Binding SurfaceBorderBrush}" />

                            <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                                <Border Width="3" Height="22" CornerRadius="2" Background="{Binding AccentBrush}" />
                                <TextBlock FontSize="18"
                                           FontWeight="SemiBold"
                                           Foreground="{Binding PrimaryTextBrush}"
                                           VerticalAlignment="Center"
                                           Text="About" />
                            </StackPanel>

                            <Grid ColumnDefinitions="Auto,*" VerticalAlignment="Center">
                                <StackPanel Grid.Column="0"
                                            Orientation="Horizontal"
                                            Spacing="14"
                                            VerticalAlignment="Center">
                                    <Border Width="3"
                                            Height="48"
                                            CornerRadius="2"
                                            Background="{Binding AccentBrush}" />
                                    <Border Width="48"
                                            Height="48"
                                            CornerRadius="12"
                                            ClipToBounds="True">
                                        <Image Source="/Assets/kodo-logo.png"
                                               Stretch="UniformToFill" />
                                    </Border>
                                    <StackPanel Spacing="2" VerticalAlignment="Center">
                                        <TextBlock FontSize="16"
                                                   FontWeight="SemiBold"
                                                   Foreground="{Binding PrimaryTextBrush}"
                                                   Text="Kodo" />
                                        <TextBlock FontSize="12"
                                                   Foreground="{Binding MutedTextBrush}"
                                                   Text="Code fast. Stay light." />
                                    </StackPanel>
                                </StackPanel>
                                <TextBlock Grid.Column="1"
                                           FontSize="13"
                                           Foreground="{Binding MutedTextBrush}"
                                           VerticalAlignment="Center"
                                           HorizontalAlignment="Right"
                                           Text="{Binding CurrentAppVersionDisplay}" />
                            </Grid>

                            <TextBlock Foreground="{Binding MutedTextBrush}"
                                       Text="{Binding CopyrightText}" />

                            <Border IsVisible="{Binding IsNewerVersionAvailable}"
                                    Background="{Binding AccentBrush}"
                                    CornerRadius="8"
                                    Padding="12,8">
                                <Grid ColumnDefinitions="*,Auto">
                                    <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                                        <TextBlock FontSize="13"
                                                   Foreground="{Binding AccentForegroundBrush}"
                                                   VerticalAlignment="Center"
                                                   Text="Update available -" />
                                        <TextBlock FontSize="13"
                                                   FontWeight="SemiBold"
                                                   Foreground="{Binding AccentForegroundBrush}"
                                                   VerticalAlignment="Center"
                                                   Text="{Binding LatestReleaseTag}" />
                                    </StackPanel>
                                    <Button Grid.Column="1"
                                            Classes="chrome"
                                            Click="OpenReleasesPageButton_OnClick"
                                            VerticalAlignment="Center"
                                            ToolTip.Tip="Download the latest version of Kodo"
                                            Content="Download" />
                                </Grid>
                            </Border>

                            <Border Height="1"
                                    Background="{Binding SurfaceBorderBrush}" />

                            <Border Background="{Binding WindowBackgroundBrush}"
                                    BorderBrush="{Binding SurfaceBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="14"
                                    Padding="18">
                                <StackPanel Spacing="14">
                                    <Grid ColumnDefinitions="*,Auto"
                                          ColumnSpacing="16">
                                        <StackPanel Orientation="Horizontal"
                                                    Spacing="14">
                                            <Border Width="42"
                                                    Height="42"
                                                    CornerRadius="12"
                                                    ClipToBounds="True"
                                                    VerticalAlignment="Center">
                                                <Image Source="/Assets/kodo-logo.png"
                                                       Stretch="UniformToFill" />
                                            </Border>
                                            <StackPanel Spacing="2"
                                                        VerticalAlignment="Center">
                                                <TextBlock FontSize="16"
                                                           FontWeight="SemiBold"
                                                           Foreground="{Binding PrimaryTextBrush}"
                                                           Text="What's New" />
                                                <TextBlock FontSize="13"
                                                           Foreground="{Binding MutedTextBrush}"
                                                           Text="{Binding LatestReleaseDisplayName}" />
                                            </StackPanel>
                                        </StackPanel>

                                        <Button Grid.Column="1"
                                                Classes="chrome"
                                                Click="ToggleWhatsNewExpandedButton_OnClick"
                                                MinWidth="164"
                                                ToolTip.Tip="Show or hide release notes"
                                                HorizontalContentAlignment="Center">
                                            <StackPanel Orientation="Horizontal"
                                                        Spacing="8"
                                                        HorizontalAlignment="Center">
                                                <TextBlock FontSize="14"
                                                           Foreground="{Binding PrimaryTextBrush}"
                                                           Text="{Binding WhatsNewToggleGlyph}" />
                                                <TextBlock Foreground="{Binding PrimaryTextBrush}"
                                                           Text="{Binding WhatsNewToggleText}" />
                                            </StackPanel>
                                        </Button>
                                    </Grid>

                                    <TextBlock Foreground="{Binding MutedTextBrush}"
                                               TextWrapping="Wrap"
                                               Text="{Binding LatestReleaseStatusText}" />

                                    <Border IsVisible="{Binding IsWhatsNewExpanded}"
                                            Background="{Binding CardBrush}"
                                            BorderBrush="{Binding SurfaceBorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="12"
                                            Padding="16">
                                        <StackPanel Spacing="12">
                                            <Grid ColumnDefinitions="*,Auto"
                                                  ColumnSpacing="16">
                                                <StackPanel Spacing="4">
                                                    <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                                                        <Border Width="3" Height="26" CornerRadius="2" Background="{Binding AccentBrush}" />
                                                        <TextBlock FontSize="22"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="{Binding PrimaryTextBrush}"
                                                                   VerticalAlignment="Center"
                                                                   Text="{Binding LatestReleaseDisplayName}" />
                                                    </StackPanel>
                                                    <TextBlock FontSize="13"
                                                               Foreground="{Binding MutedTextBrush}"
                                                               Text="{Binding LatestReleaseTag}" />
                                                </StackPanel>
                                                <StackPanel Grid.Column="1"
                                                            Orientation="Horizontal"
                                                            Spacing="8"
                                                            VerticalAlignment="Top">
                                                    <Button Classes="chrome"
                                                            Click="RefreshLatestReleaseButton_OnClick"
                                                            IsEnabled="{Binding !IsRefreshingLatestRelease}"
                                                            ToolTip.Tip="Check for newer release information"
                                                            Content="{Binding RefreshLatestReleaseButtonText}" />
                                                    <Button Classes="chrome"
                                                            Click="OpenLatestReleaseButton_OnClick"
                                                            ToolTip.Tip="Open this release on GitHub in your browser"
                                                            Content="View on GitHub" />
                                                </StackPanel>
                                            </Grid>

                                            <TextBlock FontSize="16"
                                                       FontWeight="SemiBold"
                                                       Foreground="{Binding PrimaryTextBrush}"
                                                       Text="Release Notes" />

                                            <ScrollViewer MaxHeight="300"
                                                          VerticalScrollBarVisibility="Auto">
                                                <SelectableTextBlock Foreground="{Binding MutedTextBrush}"
                                                                     TextWrapping="Wrap"
                                                                     Text="{Binding LatestReleaseNotes}" />
                                            </ScrollViewer>

                                            <StackPanel Spacing="10"
                                                        IsVisible="{Binding HasLatestReleaseLinks}">
                                                <TextBlock FontSize="16"
                                                           FontWeight="SemiBold"
                                                           Foreground="{Binding PrimaryTextBrush}"
                                                           Text="Links" />
                                                <ItemsControl ItemsSource="{Binding LatestReleaseLinks}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate x:DataType="kodo:ReleaseLinkItem">
                                                            <Button Classes="chrome"
                                                                    Tag="{Binding Url}"
                                                                    Click="OpenReleaseLinkButton_OnClick"
                                                                    HorizontalAlignment="Left"
                                                                    HorizontalContentAlignment="Left"
                                                                    Margin="0,0,0,6">
                                                                <StackPanel Spacing="2">
                                                                    <TextBlock Foreground="{Binding #RootWindow.PrimaryTextBrush}"
                                                                               Text="Full Changelog"
                                                                               TextWrapping="Wrap" />
                                                                    <TextBlock FontSize="12"
                                                                               Foreground="{Binding #RootWindow.MutedTextBrush}"
                                                                               Text="{Binding Url}"
                                                                               TextWrapping="Wrap" />
                                                                </StackPanel>
                                                            </Button>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>
                </Grid>
                </ScrollViewer>
            </Grid>
            </Panel>
        </Grid>
    </Grid>
</Window>
