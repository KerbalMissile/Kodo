<!-- April 19th, 2026 - KerbalMissile - Changed "Simple Code Editor" to "Get Started!", added WIP comment to new file in the UI changed open file icon to be more descriptive -->
<!-- April 19th, 2026 - SS-YYC - Removed "Pick a Theme" from the top of the settings menu as this will be expanded. -->
<!-- April 19th, 2026 - SS-YYC - Changed a couple emojis on the left sidebar -->
<!-- April 19th, 2026 - KerbalMissile - Removed top right Open, Save, etc. buttons -->
<!-- April 19th, 2026 - KerbalMissile - Re-added Save button to the top right -->
<!-- April 19th, 2026 - KerbalMissile - Make Kodo start maximized -->
<!-- April 19th, 2026 - KerbalMissile - Updated Editor Icon to Pen-->
<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        x:Class="Kodo.MainWindow"
        x:CompileBindings="False"
        Width="1920"
        Height="1080"
        WindowState="Maximized"
        MinWidth="900"
        MinHeight="620"
        Title="Kodo"
        Background="{Binding WindowBackgroundBrush}"
        KeyDown="MainWindow_OnKeyDown">
    <Window.Styles>
        <Style Selector="Button.chrome">
            <Setter Property="Background" Value="{Binding ButtonBrush}" />
            <Setter Property="Foreground" Value="{Binding PrimaryTextBrush}" />
            <Setter Property="BorderBrush" Value="{Binding SurfaceBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="12,8" />
        </Style>

        <Style Selector="Button.chrome:pointerover">
            <Setter Property="Background" Value="{Binding ButtonHoverBrush}" />
        </Style>

        <Style Selector="Button.activity">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{Binding MutedTextBrush}" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="10,12" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
        </Style>

        <Style Selector="Button.activity:pointerover">
            <Setter Property="Background" Value="{Binding ButtonHoverBrush}" />
            <Setter Property="Foreground" Value="{Binding PrimaryTextBrush}" />
        </Style>

        <Style Selector="TextBox.editor">
            <Setter Property="Background" Value="{Binding EditorBackgroundBrush}" />
            <Setter Property="Foreground" Value="{Binding PrimaryTextBrush}" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="20,18" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontFamily" Value="Cascadia Code,Consolas,Menlo,Monospace" />
            <Setter Property="TextWrapping" Value="NoWrap" />
            <Setter Property="AcceptsReturn" Value="True" />
            <Setter Property="AcceptsTab" Value="True" />
            <Setter Property="FocusAdorner" Value="{x:Null}" />
            <Setter Property="CornerRadius" Value="0" />
        </Style>

        <Style Selector="TextBox.editor:focus">
            <Setter Property="BorderBrush" Value="Transparent" />
        </Style>
    </Window.Styles>

    <Grid ColumnDefinitions="60,*">
        <Border Grid.Column="0"
                Background="{Binding SidebarBrush}"
                BorderBrush="{Binding SurfaceBorderBrush}"
                BorderThickness="0,0,1,0">
            <Grid RowDefinitions="Auto,*,Auto">
                <StackPanel Margin="8,12,8,0" Spacing="4">
                    <Button Classes="activity" Click="EditorButton_OnClick" ToolTip.Tip="Editor (Ctrl+Shift+E)">
                        <TextBlock FontSize="24" Text="✍︎" />
                    </Button>
                    <Button Classes="activity" Click="NewFileButton_OnClick" ToolTip.Tip="New File (Ctrl+N)">
                        <TextBlock FontSize="18" Text="＋" />
                    </Button>
                    <Button Classes="activity" Click="OpenFileButton_OnClick" ToolTip.Tip="Open File (Ctrl+O)">
                        <TextBlock FontSize="20" Text=" 🗎" />
                    </Button>
                    <Button Classes="activity" Click="SaveButton_OnClick" ToolTip.Tip="Save File (Ctrl+S)" IsEnabled="{Binding IsSaveEnabled}">
                        <TextBlock FontSize="18" Text=" ⭳" />
                    </Button>
                </StackPanel>

                <StackPanel Grid.Row="2" Margin="8,0,8,12" Spacing="4">
                    <Button Classes="activity" Click="SettingsButton_OnClick" ToolTip.Tip="Settings">
                        <TextBlock FontSize="18" Text="⚙" />
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Column="1">
            <Grid IsVisible="{Binding IsEditorPageVisible}" RowDefinitions="Auto,*,Auto">
                <Border Grid.Row="0"
                        Background="{Binding TopBarBrush}"
                        BorderBrush="{Binding SurfaceBorderBrush}"
                        BorderThickness="0,0,0,1"
                        Padding="18,14">
                    <Grid ColumnDefinitions="*,Auto">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <Border Width="28"
                                    Height="28"
                                    CornerRadius="8"
                                    Background="{Binding AccentBrush}">
                                <TextBlock HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           FontSize="14"
                                           FontWeight="SemiBold"
                                           Foreground="White"
                                           Text="K" />
                            </Border>

                            <StackPanel Spacing="2">
                                <TextBlock FontSize="18"
                                           FontWeight="SemiBold"
                                           Foreground="{Binding PrimaryTextBrush}"
                                           Text="Kodo" />
                                <TextBlock FontSize="12"
                                           Foreground="{Binding MutedTextBrush}"
                                           Text="{Binding FileSummaryText}" />
                            </StackPanel>
                        </StackPanel>

                        <StackPanel Grid.Column="1"
                                    Orientation="Horizontal"
                                    Spacing="8">
                                <Button Classes="chrome"
                                Click="SaveButton_OnClick"
                                Content="Save" />
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Grid.Row="1"
                        Background="{Binding CardBrush}"
                        BorderBrush="{Binding SurfaceBorderBrush}"
                        BorderThickness="0"
                        IsVisible="{Binding HasDocumentOpen}">
                    <TextBox x:Name="EditorTextBox"
                             Classes="editor"
                             Background="{Binding CardBrush}"
                             Text="{Binding EditorContent, Mode=TwoWay}"
                             TextChanged="EditorTextBox_OnTextChanged" />
                </Border>

                <Border Grid.Row="1"
                        Background="{Binding EditorBackgroundBrush}"
                        IsVisible="{Binding IsEmptyStateVisible}">
                    <Grid Margin="48">
                        <Border Width="480"
                                Padding="26"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Background="{Binding CardBrush}"
                                BorderBrush="{Binding SurfaceBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="18">
                            <StackPanel Spacing="12">
                                <TextBlock FontSize="26"
                                           FontWeight="SemiBold"
                                           Foreground="{Binding PrimaryTextBrush}"
                                           Text="Get Started!" />
                                <TextBlock Foreground="{Binding MutedTextBrush}"
                                           Text="Open one file, edit it, save it. Or start a new file." />
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <Button Classes="chrome"
                                            Click="OpenFileButton_OnClick"
                                            Content="Open File" />
                                    <Button Classes="chrome"
                                            Click="NewFileButton_OnClick"
                                            Content="New File" />
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>

                <Border Grid.Row="2"
                        Background="{Binding TopBarBrush}"
                        BorderBrush="{Binding SurfaceBorderBrush}"
                        BorderThickness="0,1,0,0"
                        Padding="16,10">
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Foreground="{Binding MutedTextBrush}"
                                   Text="{Binding FilePathText}" />
                        <TextBlock Grid.Column="1"
                                   Foreground="{Binding MutedTextBrush}"
                                   Text="{Binding EditorStatsText}" />
                    </Grid>
                </Border>
            </Grid>

            <Grid IsVisible="{Binding IsSettingsPageVisible}"
                  Background="{Binding EditorBackgroundBrush}"
                  RowDefinitions="Auto,*">
                <Border Grid.Row="0"
                        Background="{Binding TopBarBrush}"
                        BorderBrush="{Binding SurfaceBorderBrush}"
                        BorderThickness="0,0,0,1"
                        Padding="24,18">
                    <Grid ColumnDefinitions="*,Auto">
                        <StackPanel Spacing="4">
                            <TextBlock FontSize="28"
                                       FontWeight="SemiBold"
                                       Foreground="{Binding PrimaryTextBrush}"
                                       Text="Settings" />
                        </StackPanel>

                        <Button Grid.Column="1"
                                Classes="chrome"
                                Click="BackToEditorButton_OnClick"
                                Content="Back" />
                    </Grid>
                </Border>

                <Grid Grid.Row="1" Margin="24">
                    <Border Background="{Binding CardBrush}"
                            BorderBrush="{Binding SurfaceBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="18"
                            Padding="22"
                            MaxWidth="620"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Top">
                        <StackPanel Spacing="16">
                            <TextBlock FontSize="18"
                                       FontWeight="SemiBold"
                                       Foreground="{Binding PrimaryTextBrush}"
                                       Text="Theme" />
                            <Grid ColumnDefinitions="*,*" ColumnSpacing="14">
                                <Button Grid.Column="0"
                                        Classes="chrome"
                                        Click="ThemeButton_OnClick"
                                        Tag="Dark">
                                    <StackPanel Spacing="8">
                                        <Border Height="96"
                                                CornerRadius="12"
                                                Background="#1E1E1E"
                                                BorderBrush="#2B2B2B"
                                                BorderThickness="1" />
                                        <TextBlock HorizontalAlignment="Center"
                                                   Foreground="{Binding PrimaryTextBrush}"
                                                   Text="Dark" />
                                    </StackPanel>
                                </Button>

                                <Button Grid.Column="1"
                                        Classes="chrome"
                                        Click="ThemeButton_OnClick"
                                        Tag="Light">
                                    <StackPanel Spacing="8">
                                        <Border Height="96"
                                                CornerRadius="12"
                                                Background="#FFFFFF"
                                                BorderBrush="#D7DCE5"
                                                BorderThickness="1" />
                                        <TextBlock HorizontalAlignment="Center"
                                                   Foreground="{Binding PrimaryTextBrush}"
                                                   Text="Light" />
                                    </StackPanel>
                                </Button>
                            </Grid>

                            <TextBlock Foreground="{Binding MutedTextBrush}"
                                       Text="{Binding ThemeStatusText}" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</Window>
